        "lineageTag": "6ae498e9-b1cb-4e2d-ac31-4890e2798b3e",
        "measures": [
          {
            "name": "Total Orders",
            "expression": [
              "",
              "DISTINCTCOUNT('Restaurant Operations'[Order_ID])"
            ],
            "formatString": "0",
            "lineageTag": "af3f5d31-71f4-420d-a6be-0ce0784cc409"
          },
          {
            "name": "Total Revenue",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"bn-IN\"}"
              }
            ],
            "expression": [
              "",
              "SUM('Restaurant Operations'[Net_Revenue])"
            ],
            "formatString": "\"₹\"\\ #,0.00;#,0.00\\ -\"₹\";\"₹\"\\ #,0.00",
            "lineageTag": "4932430d-a6eb-4547-b1ea-d3c911dddf84"
          },
          {
            "name": "Total Qty",
            "expression": [
              "",
              "SUM('Restaurant Operations'[Qty])"
            ],
            "formatString": "0",
            "lineageTag": "ff8f0bba-51cd-4c84-9c7e-c56636a6346b"
          },
          {
            "name": "Avg Order Value",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "DIVIDE([Total Revenue],[Total Orders])"
            ],
            "lineageTag": "db8e5cd3-0158-4691-9e55-cb4f699454dc"
          },
          {
            "name": "Avg Rating",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "AVERAGE('Restaurant Operations'[Rating])"
            ],
            "lineageTag": "b6842d73-b455-4f96-9ebb-a32490392779"
          },
          {
            "name": "Previous Orders",
            "expression": [
              "",
              "CALCULATE(",
              "[Total Orders],",
              "DATEADD('Date Table'[Date],-1,MONTH)",
              ")"
            ],
            "lineageTag": "4f7af3e2-d71e-4472-afd8-78e85e790b5f"
          },
          {
            "name": "Order Growth %",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "DIVIDE(",
              "[Total Orders]-[Previous Orders],",
              "[Previous Orders]",
              ")"
            ],
            "lineageTag": "5cd91940-4d23-4792-a40f-260af2492a1c"
          },
          {
            "name": "Order Trend",
            "expression": [
              "",
              "IF(",
              "[Order Growth %] >= 0,",
              "\"↑ \" & FORMAT([Order Growth %],\"0.0%\"),",
              "\"↓ \" & FORMAT(ABS([Order Growth %]),\"0.0%\")",
              ")"
            ],
            "lineageTag": "5172158b-38a5-444a-94cb-3e6678daba37"
          },
          {
            "name": "Previous Revenue",
