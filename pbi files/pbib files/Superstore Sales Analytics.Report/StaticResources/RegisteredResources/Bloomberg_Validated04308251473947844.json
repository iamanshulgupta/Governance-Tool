        "visualHeader": [
          {
            "foreground": {
              "solid": {
                "color": "#000000"
              }
            },
            "background": {
              "solid": {
                "color": "#FFFFFF"
              }
            }
          }
        ],
        "outspace": [
          {
            "color": {
              "solid": {
                "color": "#000B1A"
              }
            }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": {
              "solid": {
                "color": "#DBDBDB"
              }
            },
            "foregroundColor": {
              "solid": {
                "color": "#000000"
              }
            }
          }
        ],
        "filterCard": [
          {
            "$id": "Available",
            "backgroundColor": {
              "solid": {
                "color": "#C6C6C6"
              }
            },
            "transparency": 0
          }
        ],
        "visualTooltip": [
          {
