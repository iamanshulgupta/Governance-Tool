          {
            "name": "Revenue Sparkline Monthly",
            "description": "SVG sparkline chart showing monthly trend of Net Revenue",
            "displayFolder": "Revenue",
            "expression": [
              "VAR LineColour = \"#FFD700\"",
              "VAR Pointcolour = \"#FFD700\"",
              "VAR Defs = \"<defs>",
              "    <linearGradient id='grad' x1='0' y1='0' x2='0' y2='1'>",
              "        <stop offset='0%' stop-color='#FFD700' />",
              "        <stop offset='100%' stop-color='#D3D3D3' stop-opacity='0.2' />",
              "    </linearGradient>",
              "</defs>\"",
              "",
              "VAR MonthlyTable = ",
              "    ADDCOLUMNS(",
              "        SUMMARIZE(",
              "            'DateTable',",
              "            DateTable[Year],         ",
              "            DateTable[Month],  ",
              "            DateTable[MonthStart]    ",
              "        ),",
              "        \"MonthlyRevenue\", CALCULATE([Net Revenue])",
              "    )",
              "",
              "",
              "VAR XMinMonth = MINX(MonthlyTable, [MonthStart])",
              "VAR XMaxMonth = MAXX(MonthlyTable, [MonthStart])",
              "VAR YMinValue = MINX(MonthlyTable, [MonthlyRevenue])",
              "VAR YMaxValue = MAXX(MonthlyTable, [MonthlyRevenue])",
              "",
              "",
              "VAR SparklineTable = ",
              "    ADDCOLUMNS(",
              "        MonthlyTable,",
              "        \"X\", INT(150 * DIVIDE([MonthStart] - XMinMonth, XMaxMonth - XMinMonth)),",
              "        \"Y\", INT(50  * DIVIDE([MonthlyRevenue] - YMinValue, YMaxValue - YMinValue))",
              "    )",
              "",
              "",
              "VAR Lines = CONCATENATEX(SparklineTable, [X] & \",\" & 50 - [Y], \" \", [MonthStart])",
              "",
              "VAR LastSparkYValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxMonth), [Y])",
              "VAR LastSparkXValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxMonth), [X])",
              "",
              "VAR SVGImageURL = ",
              "    \"data:image/svg+xml;utf8,\" & ",
              "    \"<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>\" & Defs & ",
              "    \"<polyline fill='url(#grad)' fill-opacity='0.3' stroke='transparent' stroke-width='0' points=' 0 50 \" & Lines & \" 150 150 Z '/>\" &",
              "    \"<polyline fill='transparent' stroke='\" & LineColour & \"' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' points=' \" & Lines & \" '/>\" &",
              "    \"<circle cx='\" & LastSparkXValue & \"' cy='\" & 50 - LastSparkYValue & \"' r='4' stroke='\" & LineColour & \"' stroke-width='2' fill='\" & Pointcolour & \"' />\" &",
              "    \"</svg>\"",
              "",
              "RETURN SVGImageURL"
            ],
            "lineageTag": "c839d1d0-8fb5-435f-9a48-13da7aa27d61"
          },
          {
            "name": "Profit Sparkline Monthly",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "SVG sparkline chart showing monthly trend of Total Profit",
            "displayFolder": "Profit Margin %",
            "expression": [
              "",
              "VAR LineColour = \"#FFD700\"",
              "VAR Pointcolour = \"#FFD700\"",
              "VAR Defs = \"<defs>",
              "    <linearGradient id='grad' x1='0' y1='0' x2='0' y2='1'>",
              "        <stop offset='0%' stop-color='#FFD700' />",
              "        <stop offset='100%' stop-color='#D3D3D3' stop-opacity='0.2' />",
              "    </linearGradient>",
              "</defs>\"",
              "",
              "VAR MonthlyTable =",
              "    ADDCOLUMNS(",
              "        SUMMARIZE(",
              "            'DateTable',",
              "            DateTable[Year],",
              "            DateTable[Month]",
              "        ),",
              "        \"MonthStart\", DATE(DateTable[Year], DateTable[Month], 1),",
              "        \"MonthlyProfit\", CALCULATE([Total Profit])",
              "    )",
              "",
              "VAR XMinDate = MINX(MonthlyTable, [MonthStart])",
              "VAR XMaxDate = MAXX(MonthlyTable, [MonthStart])",
              "VAR YMinValue = MINX(MonthlyTable, [MonthlyProfit])",
              "VAR YMaxValue = MAXX(MonthlyTable, [MonthlyProfit])",
              "",
              "VAR SparklineTable =",
              "    ADDCOLUMNS(",
              "        MonthlyTable,",
              "        \"X\", INT(150 * DIVIDE([MonthStart] - XMinDate, XMaxDate - XMinDate)),",
              "        \"Y\", INT(50 * DIVIDE([MonthlyProfit] - YMinValue, YMaxValue - YMinValue))",
              "    )",
              "",
              "VAR Lines = CONCATENATEX(SparklineTable, [X] & \",\" & 50 - [Y], \" \", [MonthStart])",
              "",
              "VAR LastSparkYValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxDate), [Y])",
              "VAR LastSparkXValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxDate), [X])",
              "",
              "VAR SVGImageURL = ",
              "    \"data:image/svg+xml;utf8,\" & ",
              "    \"<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>\" & Defs & ",
              "    \"<polyline fill='url(#grad)' fill-opacity='0.3' stroke='transparent' ",
              "     stroke-width='0' points=' 0 50 \" & Lines & ",
              "     \" 150 150 Z '/>\" &",
              "    \"<polyline ",
              "        fill='transparent' stroke='\" & LineColour & \"' ",
              "        stroke-linecap='round' stroke-linejoin='round' ",
              "        stroke-width='2' points=' \" & Lines & ",
              "     \" '/>\" &",
              "    \"<circle cx='\" & LastSparkXValue & \"' cy='\" & 50 - LastSparkYValue & \"' r='4' stroke='\" & LineColour & \"' stroke-width='2' fill='\" & Pointcolour & \"' />\" &",
              "    \"</svg>\"",
              "",
              "RETURN SVGImageURL"
            ],
            "lineageTag": "4ebe0bd3-5e7b-46c6-a179-fb1a5ff79cfa"
          },
