            "displayFolder": "Orders",
            "expression": "[Dynamic Orders]-[Dynamic Orders Target] ",
            "formatString": "0",
            "lineageTag": "703f5bfc-00b1-4846-8ba0-3ecede8c2d85"
          },
          {
            "name": "Dynamic Orders Target Gap with Arrow",
            "description": "Dynamic Orders gap vs target displayed with up/down arrow indicator",
            "displayFolder": "Orders",
            "expression": [
              "",
              "VAR uparrow = UNICHAR(9650)",
