          {
            "name": "Adjusted Revenue Target Gap with Arrow",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "Adjusted Revenue gap vs target displayed with up/down arrow indicator",
            "displayFolder": "Tariffs",
            "expression": [
              "",
              "VAR uparrow = UNICHAR(9650)",
              "VAR downarrow = UNICHAR(9660)",
              "",
              "VAR revenuegap = [Adjusted Revenue Target Gap]",
              "",
              "RETURN",
              "IF(",
              "    revenuegap < 0,",
              "    FORMAT(revenuegap, \"$#,###\") & \" \" & downarrow,",
              "    FORMAT(revenuegap, \"$#,###\") & \" \" & uparrow",
              ")"
            ],
            "lineageTag": "badf02d6-4be8-4ec7-8eb9-67c5d76d4337"
          },
          {
            "name": "Adjusted Revenue Sparkline Monthly",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "dataCategory": "ImageUrl",
            "description": "SVG sparkline chart showing monthly trend of Adjusted Revenue",
            "displayFolder": "Tariffs",
            "expression": [
              "",
              "VAR LineColour = \"#FFD700\"",
              "VAR Pointcolour = \"#FFD700\"",
              "VAR SelectedPriceIncrease = [Scenario Price Increase]",
              "VAR Defs = \"<defs>",
              "    <linearGradient id='grad' x1='0' y1='0' x2='0' y2='1'>",
              "        <stop offset='0%' stop-color='#FFD700' />",
              "        <stop offset='100%' stop-color='#D3D3D3' stop-opacity='0.2' />",
              "    </linearGradient>",
              "</defs>\"",
              "",
              "VAR MonthlyTable =",
              "    ADDCOLUMNS(",
              "        SUMMARIZE(",
              "            'DateTable',",
              "            DateTable[Year],",
              "            DateTable[Month]",
              "        ),",
              "        \"MonthStart\", DATE(DateTable[Year], DateTable[Month], 1),",
              "        \"MonthlyRevenue\", CALCULATE(",
              "            [Net Revenue] * (1 + DIVIDE(SelectedPriceIncrease, 100))",
              "        )",
              "    )",
              "",
              "VAR XMinDate = MINX(MonthlyTable, [MonthStart])",
              "VAR XMaxDate = MAXX(MonthlyTable, [MonthStart])",
              "VAR YMinValue = MINX(MonthlyTable, [MonthlyRevenue])",
              "VAR YMaxValue = MAXX(MonthlyTable, [MonthlyRevenue])",
              "",
              "VAR SparklineTable =",
              "    ADDCOLUMNS(",
              "        MonthlyTable,",
              "        \"X\", INT(150 * DIVIDE([MonthStart] - XMinDate, XMaxDate - XMinDate)),",
              "        \"Y\", INT(50 * DIVIDE([MonthlyRevenue] - YMinValue, YMaxValue - YMinValue))",
              "    )",
              "",
              "VAR Lines = CONCATENATEX(SparklineTable, [X] & \",\" & 50 - [Y], \" \", [MonthStart])",
              "",
              "VAR LastSparkYValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxDate), [Y])",
              "VAR LastSparkXValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxDate), [X])",
              "",
              "VAR SVGImageURL = ",
              "    \"data:image/svg+xml;utf8,\" & ",
              "    \"<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>\" & Defs & ",
              "    \"<polyline fill='url(#grad)' fill-opacity='0.3' stroke='transparent' ",
              "     stroke-width='0' points=' 0 50 \" & Lines & ",
              "     \" 150 150 Z '/>\" &",
              "    \"<polyline ",
              "        fill='transparent' stroke='\" & LineColour & \"' ",
              "        stroke-linecap='round' stroke-linejoin='round' ",
              "        stroke-width='2' points=' \" & Lines & ",
              "     \" '/>\" &",
              "    \"<circle cx='\" & LastSparkXValue & \"' cy='\" & 50 - LastSparkYValue & \"' r='4' stroke='\" & LineColour & \"' stroke-width='2' fill='\" & Pointcolour & \"' />\" &",
              "    \"</svg>\"",
              "",
              "RETURN SVGImageURL"
            ],
            "lineageTag": "827fb856-0ebf-4c3b-872f-b2ee1de90a71"
          },
          {
            "name": "Adjusted Profit YoY %",
            "description": "Year-over-year percentage change in Adjusted Profit compared to Total Profit last year",
            "displayFolder": "Tariffs",
            "expression": [
              "",
              "VAR CurrentRevenue = [Adjusted Profit]",
              "VAR PriorRevenue = CALCULATE([Total Profit], DATEADD(DateTable[Date], -1, YEAR))",
              "RETURN",
              "IF(",
              "    NOT ISBLANK(CurrentRevenue) && ISBLANK(PriorRevenue), ",
              "    1, ",
              "    DIVIDE(CurrentRevenue - PriorRevenue, PriorRevenue)",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "8ea44606-f35b-48ff-9835-a7e9a30de8cb"
          },
