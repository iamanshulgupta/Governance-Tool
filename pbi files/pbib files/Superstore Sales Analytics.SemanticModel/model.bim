          {
            "name": "Dynamic Profit YoY Growth",
            "description": "Year-over-year growth percentage of Dynamic Profit for the selected time period",
            "displayFolder": "Profit",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "",
              "VAR CurrentVal = [Dynamic Profit]",
              "",
              "VAR PriorYearVal = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", CALCULATE([Dynamic Profit], SAMEPERIODLASTYEAR(DATESMTD('DateTable'[Date]))),",
              "        \"QTD\", CALCULATE([Dynamic Profit], SAMEPERIODLASTYEAR(DATESQTD('DateTable'[Date]))),",
              "        \"YTD\", CALCULATE([Dynamic Profit], SAMEPERIODLASTYEAR(DATESYTD('DateTable'[Date])))",
              "    )",
              "",
              "RETURN",
              "DIVIDE(CurrentVal - PriorYearVal, PriorYearVal, 0)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "e7f8abb7-415b-4c69-bbcf-a72831daff1c"
          },
          {
            "name": "Dynamic Profit Margin YoY Growth",
            "description": "Year-over-year growth percentage of Dynamic Profit Margin % for the selected time period",
            "displayFolder": "Profit Margin %",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "",
              "VAR CurrentMargin = [Dynamic Profit Margin %]",
              "",
              "VAR PriorYearMargin = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", CALCULATE([Profit Margin %], SAMEPERIODLASTYEAR(DATESMTD('DateTable'[Date]))),",
              "        \"QTD\", CALCULATE([Profit Margin %], SAMEPERIODLASTYEAR(DATESQTD('DateTable'[Date]))),",
              "        \"YTD\", CALCULATE([Profit Margin %], SAMEPERIODLASTYEAR(DATESYTD('DateTable'[Date])))",
              "    )",
              "",
              "RETURN",
              "CurrentMargin - PriorYearMargin"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "d8fc012a-539a-49c6-83bb-e136c61cc117"
          },
