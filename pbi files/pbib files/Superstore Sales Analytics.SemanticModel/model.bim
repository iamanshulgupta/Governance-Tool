                "property": "IsHidden"
              }
            ],
            "dataCategory": "ImageUrl",
            "description": "SVG sparkline chart showing monthly trend of Adjusted Cost",
            "displayFolder": "Tariffs",
            "expression": [
              "",
              "VAR LineColour = \"#FFD700\"",
              "VAR Pointcolour = \"#FFD700\"",
              "VAR Defs = \"<defs>",
              "    <linearGradient id='grad' x1='0' y1='0' x2='0' y2='1'>",
              "        <stop offset='0%' stop-color='#FFD700' />",
              "        <stop offset='100%' stop-color='#D3D3D3' stop-opacity='0.2' />",
              "    </linearGradient>",
              "</defs>\"",
              "",
              "VAR MonthlyTable = ",
              "    ADDCOLUMNS(",
              "        SUMMARIZE(",
              "            'DateTable',",
              "            DateTable[Year],        ",
              "            DateTable[Month], ",
              "            DateTable[MonthStart]    ",
              "        ),",
              "        \"MonthlyRevenue\", CALCULATE([Adjusted Cost])",
              "    )",
              "",
              "VAR XMinMonth = MINX(MonthlyTable, [MonthStart])",
              "VAR XMaxMonth = MAXX(MonthlyTable, [MonthStart])",
              "VAR YMinValue = MINX(MonthlyTable, [MonthlyRevenue])",
              "VAR YMaxValue = MAXX(MonthlyTable, [MonthlyRevenue])",
              "",
              "VAR SparklineTable = ",
              "    ADDCOLUMNS(",
              "        MonthlyTable,",
              "        \"X\", INT(150 * DIVIDE([MonthStart] - XMinMonth, XMaxMonth - XMinMonth)),",
              "        \"Y\", INT(50  * DIVIDE([MonthlyRevenue] - YMinValue, YMaxValue - YMinValue))",
              "    )",
              "",
              "VAR Lines = CONCATENATEX(SparklineTable, [X] & \",\" & 50 - [Y], \" \", [MonthStart])",
              "",
              "VAR LastSparkYValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxMonth), [Y])",
              "VAR LastSparkXValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxMonth), [X])",
              "",
              "VAR SVGImageURL = ",
              "    \"data:image/svg+xml;utf8,\" & ",
              "    \"<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>\" & Defs & ",
              "    \"<polyline fill='url(#grad)' fill-opacity='0.3' stroke='transparent' stroke-width='0' points=' 0 50 \" & Lines & \" 150 150 Z '/>\" &",
              "    \"<polyline fill='transparent' stroke='\" & LineColour & \"' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' points=' \" & Lines & \" '/>\" &",
              "    \"<circle cx='\" & LastSparkXValue & \"' cy='\" & 50 - LastSparkYValue & \"' r='4' stroke='\" & LineColour & \"' stroke-width='2' fill='\" & Pointcolour & \"' />\" &",
              "    \"</svg>\"",
              "",
              "RETURN SVGImageURL"
            ],
            "lineageTag": "467a73e7-c84d-4437-8d20-bbb146a8717f"
          },
          {
            "name": "Scenario Price Increase",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "description": "Selected price increase percentage from the Scenarios table, defaulting to the Price Increase Rate Value",
            "displayFolder": "Tariffs",
            "expression": [
              "",
              "SELECTEDVALUE(Scenarios[Price Increase], [Price Increase Rate Value])"
            ],
            "lineageTag": "2b984570-b4e3-4d13-8360-be5277cf4f19"
          },
          {
            "name": "Scenario Tariff Rate",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "description": "Selected tariff rate percentage from the Scenarios table, defaulting to the Tariff Rate Value",
            "displayFolder": "Tariffs",
            "expression": [
              "",
              "SELECTEDVALUE(Scenarios[Tariff Rate], [Tariff Rate Value])"
            ],
            "lineageTag": "02d3045c-62c4-42a3-89bc-b161746051c4"
          },
          {
            "name": "Tariff Impact",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "description": "Dollar impact on Total Cost from applying the Scenario Tariff Rate",
            "displayFolder": "Tariffs",
            "expression": "[Total Cost] * DIVIDE([Scenario Tariff Rate], 100)",
            "lineageTag": "d062352b-7001-432b-8fee-8f4e7d10fa8a"
          },
          {
            "name": "Waterfall Value",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "description": "Value used in waterfall chart showing Baseline Profit, Tariff Impact, and Price Increase Benefit",
            "displayFolder": "Tariffs",
            "expression": [
              "",
              "SWITCH(",
              "    SELECTEDVALUE(WaterfallSteps[Metric]),",
              "    \"Baseline Profit\", [Total Profit],",
              "    \"Tariff Impact\", -[Tariff Impact],",
              "    \"Price Increase Benefit\", [Adjusted Revenue] - [Net Revenue]",
              ")"
            ],
            "lineageTag": "c1fea4ba-1c54-4a67-8a68-8a29a96aedba"
          }
        ],
