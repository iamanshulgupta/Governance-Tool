        "description": "Field parameter table allowing dynamic switching between key metrics (Revenue, Profit, Margin, Cost, Shipping)",
        "isHidden": true,
        "lineageTag": "fae477b4-e5a7-4dd7-844a-e7fdd121575b",
        "partitions": [
          {
            "name": "Parameter",
            "mode": "import",
            "source": {
              "expression": [
                "{",
                "    (\"Revenue\", NAMEOF('_Key Metrics'[Net Revenue]), 0),",
                "    (\"Profit\", NAMEOF('_Key Metrics'[Total Profit]), 1),",
                "    (\"Profit Margin %\", NAMEOF('_Key Metrics'[Profit Margin %]), 2),",
                "    (\"Total Cost\", NAMEOF('_Key Metrics'[Total Cost]), 3),",
                "    (\"Shipping Costs\", NAMEOF('_Other Measures'[Shipping Costs]), 4)",
                "    ",
                "",
                "}"
              ],
              "type": "calculated"
            }
          }
        ]
      },
