                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "formatString": "0",
            "isHidden": true,
            "lineageTag": "89fe9105-a84e-4990-91ec-88f0ca126ae8",
            "sourceColumn": "Ordinal",
            "summarizeBy": "sum"
          }
        ],
        "description": "Calculated Group providing aggregation options ",
        "isHidden": true,
        "lineageTag": "80b293f2-4175-4311-a0aa-4768919fd63a",
        "measures": [
          {
            "name": "Matrix Dynamic Title",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "Dynamic title for the matrix visual combining selected dimension, metric, and aggregation",
            "expression": [
              "",
              "VAR SelectedDimension =",
              "    CONCATENATEX(",
              "        ALLSELECTED('Dimension Switcher'),",
              "        'Dimension Switcher'[Dimension Switcher],",
              "        \", \"",
              "    )",
              "",
              "VAR SelectedField =",
              "    CONCATENATEX(",
              "        ALLSELECTED('Parameter'),",
              "        'Parameter'[Metric Switch],",
              "        \", \"",
              "    )",
              "",
              "VAR SelectedCalc =",
              "    SELECTEDVALUE('Summary Statistics'[Aggregation], \"Value\")",
              "",
              "RETURN",
              "SelectedCalc & \" of \" & SelectedField & \" by \" & SelectedDimension"
            ],
            "isHidden": true,
            "lineageTag": "d46a3e51-819b-4dff-a4e0-e54500e38a1c"
          }
        ],
        "partitions": [
          {
            "name": "Summary Statistics",
            "mode": "import",
            "source": {
              "type": "calculationGroup"
            }
          }
        ]
      },
