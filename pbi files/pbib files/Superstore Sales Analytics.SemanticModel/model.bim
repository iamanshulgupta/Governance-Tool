          {
            "name": "Discount % (bins)",
            "annotations": [
              {
                "name": "GroupingDesignState",
                "value": "{\"Version\":0,\"Sources\":[{\"Name\":\"s\",\"Entity\":\"Sales\"}],\"GroupedColumns\":[{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"s\"}},\"Property\":\"Discount %\"}}],\"BinItem\":{\"Expression\":{\"Member\":{\"Expression\":{\"Discretize\":{\"Expression\":{\"Column\":{\"Expression\":{\"SourceRef\":{\"Source\":\"s\"}},\"Property\":\"Discount %\"}},\"Count\":4}},\"Member\":\"Min\"}}}}"
              },
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "dataType": "double",
            "description": "Calculated column grouping Discount % into 4 equal-width bins for distribution analysis",
            "expression": [
              "VAR __Count = 4",
              "",
              "VAR __Min = MIN('Sales'[Discount %])",
              "",
              "VAR __Max = MAX('Sales'[Discount %])",
              "",
              "VAR __Difference = (__Max - __Min)",
              "",
              "VAR __Size = IF(__Difference > 0, __Difference / __Count, 1)",
              "",
              "VAR __BinNumber = ",
              "\tIF(",
              "\t\tISBLANK('Sales'[Discount %]),",
              "\t\tBLANK(),",
              "\t\tROUNDDOWN(('Sales'[Discount %] - __Min) / __Size, 0)",
              "\t)",
              "",
              "RETURN",
              "\tIF(",
              "\t\tISBLANK('Sales'[Discount %]),",
              "\t\tBLANK(),",
              "\t\t__Min + (MIN(__BinNumber, __Count - 1) * __Size)",
              "\t)"
            ],
            "extendedProperties": [
              {
                "name": "GroupingMetadata",
                "type": "json",
                "value": {
                  "groupedColumns": [
                    {
                      "Column": {
                        "Expression": {
                          "SourceRef": {
                            "Entity": "Sales"
                          }
                        },
                        "Property": "Discount %"
                      }
                    }
                  ],
                  "version": 0
                }
              }
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "isDataTypeInferred": true,
            "lineageTag": "d12e2c84-fd10-4dbb-8fa4-c7e58eb623af",
            "summarizeBy": "none",
