        "partitions": [
          {
            "name": "WaterfallSteps",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText(\"i45WMlTSUQpKLUvNK01VitWJVjIC8kPySxJzFJzzi0vAQsYgocSizLQ0Bc/cgsRkiKgJUNQxJau0uCQ1RSGgKD8tEygeCwA=\", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Order = _t, Metric = _t]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Order\", Int64.Type}, {\"Metric\", type text}}),",
                "    #\"Replaced Value\" = Table.ReplaceValue(#\"Changed Type\",\"Adjusted Profit\",\"Profit\",Replacer.ReplaceText,{\"Metric\"}),",
                "    #\"Replaced Value1\" = Table.ReplaceValue(#\"Replaced Value\",\"Revenue\",\"Baseline Profit\",Replacer.ReplaceText,{\"Metric\"}),",
                "    #\"Replaced Value2\" = Table.ReplaceValue(#\"Replaced Value1\",\"Tariff Impact\",\"Price Increase Benefit\",Replacer.ReplaceText,{\"Metric\"}),",
                "    #\"Replaced Value3\" = Table.ReplaceValue(#\"Replaced Value2\",\"Total Cost\",\"Tariff Impact\",Replacer.ReplaceText,{\"Metric\"}),",
                "    #\"Replaced Value4\" = Table.ReplaceValue(#\"Replaced Value3\",\"Profit\",\"Adjusted Profit\",Replacer.ReplaceText,{\"Metric\"}),",
                "    #\"Replaced Value5\" = Table.ReplaceValue(#\"Replaced Value4\",\"Baseline Adjusted Profit\",\"Baseline Profit\",Replacer.ReplaceText,{\"Metric\"})",
                "in",
                "    #\"Replaced Value5\""
              ],
              "type": "m"
            }
          }
        ]
      },
