          {
            "name": "Revenue YoY %",
            "description": "Calculates Revenue YoY %",
            "displayFolder": "Revenue",
            "expression": [
              "",
              "VAR CurrentRevenue = [Net Revenue]",
              "VAR PriorRevenue = CALCULATE([Net Revenue], DATEADD(DateTable[Date], -1, YEAR))",
              "RETURN",
              "IF(",
              "    NOT ISBLANK(CurrentRevenue) && ISBLANK(PriorRevenue), ",
              "    1, ",
              "    DIVIDE(CurrentRevenue - PriorRevenue, PriorRevenue)",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "6118ec3a-cfbd-4649-949d-8ea2233e4018"
          },
