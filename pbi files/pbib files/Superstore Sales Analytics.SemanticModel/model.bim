                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "formatString": "0",
            "isDataTypeInferred": true,
            "isNameInferred": true,
            "lineageTag": "4e79f0b0-9fce-4383-9867-bac33f2b72a7",
            "sourceColumn": "[Column]",
            "summarizeBy": "sum",
            "type": "calculatedTableColumn"
          }
        ],
        "description": "Hidden placeholder table hosting secondary and supporting measures",
        "lineageTag": "3580061a-2917-4872-a005-1ac55e9ba862",
        "measures": [
          {
            "name": "Last Refreshed",
            "description": "Timestamp label showing the last data refresh date and time",
            "expression": [
              "",
              "\"Last Updated: \" & FORMAT(NOW(), \"dd MMM yyyy HH:mm\")"
            ],
            "lineageTag": "c4c5885d-009b-44c5-b2c0-9f5342bc7b0f"
          },
          {
            "name": "Time-Intelligence Card Title",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "Dynamic full-name title for time intelligence cards (Month-to-Date, Quarter-to-Date, Year-to-Date)",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "VAR FullName = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", \"Month-to-Date\",",
              "        \"QTD\", \"Quarter-to-Date\",",
              "        \"YTD\", \"Year-to-Date\",",
              "        \"Year-to-Date\"",
              "    )",
              "RETURN",
              "FullName"
            ],
            "lineageTag": "23efcba0-2c15-4b02-a88b-a8e6970bcc5a"
          },
          {
            "name": "Time-Intelligence Treemap Title",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "Dynamic title for the revenue by category treemap based on selected period",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "VAR FullName = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", \"MTD\",",
              "        \"QTD\", \"QTD\",",
              "        \"YTD\", \"YTD\",",
              "        \"Year-to-Date\"",
              "    )",
              "RETURN",
              "\"Revenue by Category - \" & FullName"
            ],
            "lineageTag": "fdbbdf1e-3bc8-42b6-9141-a7c6f7b03483"
          },
          {
            "name": "Time-Intelligence Table Title",
            "description": "Dynamic title for category/sub-category table based on selected period",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "VAR FullName = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", \"MTD\",",
              "        \"QTD\", \"QTD\",",
              "        \"YTD\", \"YTD\",",
              "        \"Year-to-Date\"",
              "    )",
              "RETURN",
              "\"Category / Sub-Category - \" & FullName & \" Details\""
            ],
            "lineageTag": "334d8e28-2310-4fcf-a167-eeb8cc3de865"
          },
          {
            "name": "Time-Intelligence Donut Title",
            "description": "Dynamic title for the revenue by segment donut chart based on selected period",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "VAR FullName = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", \"MTD\",",
              "        \"QTD\", \"QTD\",",
              "        \"YTD\", \"YTD\",",
              "        \"Year-to-Date\"",
              "    )",
              "RETURN",
              "\"Revenue by Segment - \" & FullName"
            ],
            "lineageTag": "1e65e5cf-bcf9-427c-821e-d6bc1aac410c"
          },
          {
            "name": "Word Cloud Title",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "Dynamic title for the word cloud visual based on the selected Word Cloud Order parameter",
            "expression": [
              "",
              "VAR SelectedIndex =",
              "    SELECTEDVALUE('Word Cloud'[Word Cloud Order], 0)",
              "RETURN",
              "SWITCH(",
              "    SelectedIndex,",
              "    0, \"Product Name Patterns by Quantity\",",
              "    1, \"Product Name Patterns by Revenue\",",
              "    2, \"Product Name Patterns by Discounts\",",
              "    3, \"Product Name Patterns by Profit\",",
              "    \"Product Name Patterns\"",
              ")"
            ],
            "lineageTag": "b0a1bb63-cbb9-4ffe-b895-b8885a04b895"
          },
          {
            "name": "Time Intelligence Table Title",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "Dynamic title for the time intelligence table based on the selected period (MTD/QTD/YTD)",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "VAR FullName = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", \"MTD\",",
              "        \"QTD\", \"QTD\",",
              "        \"YTD\", \"YTD\",",
              "        \"Year-to-Date\"",
              "    )",
              "RETURN",
              "\"Category / Sub-Category - \" & FullName & \" Details\""
            ],
            "lineageTag": "309a0113-29c3-40c4-98be-9bb69a8caf92"
          },
          {
            "name": "Total Value Discounted",
            "description": "Sum of discounted sales value",
            "expression": "sum(Sales[Discounted Value])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "c80e78f4-7b06-426b-84d8-60c8a55da262"
          },
          {
            "name": "TOP Subcategory",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "Top sub-category by Net Revenue",
            "expression": "CONCATENATEX(TOPN(1, VALUES('Product'[Sub-Category]), [Net Revenue], DESC), 'Product'[Sub-Category])",
            "lineageTag": "cf85a95a-1c3f-43ef-a749-9e5571410568"
          },
          {
            "name": "AVG Cost per Product",
            "description": "Average cost per unit across all products using MAX cost per unit per product name",
            "expression": "AVERAGEX(VALUES('Product'[Product Name]), CALCULATE(MAX('Sales'[Cost per Unit])))",
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "d5321afc-bf20-419d-bbbc-57344b571a97"
          },
          {
            "name": "AVG Price per Product",
            "description": "Average price per unit across all products using MAX price per unit per product name",
            "expression": "AVERAGEX(VALUES('Product'[Product Name]), CALCULATE(MAX('Sales'[Price per Unit])))",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "cd5ff50d-f69e-4223-8ddc-80a1bc42bb4e"
          },
          {
            "name": "City AOV",
            "description": "Average Order Value by city calculated as Net Revenue divided by Orders Count",
            "expression": [
              "DIVIDE([Net Revenue], [Orders Count],0)",
              ""
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "b4ee52bb-3d35-454b-ad74-f8e806956df1"
          },
          {
            "name": "Customer Count",
            "description": "Distinct count of Customer IDs",
            "expression": "DISTINCTCOUNT(Sales[Customer ID])",
            "formatString": "0",
            "lineageTag": "48bc749f-fc23-4a28-a951-bd158a9ddf79"
          },
          {
            "name": "Freight %",
            "description": "Shipping costs as a percentage of Net Revenue",
            "expression": "DIVIDE([Shipping Costs] , [Net Revenue],0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "9749baed-1f86-4924-b4ff-97d7fca8885d"
          },
          {
            "name": "Shipping Costs",
            "description": "Sum of shipping costs from the Sales table",
            "expression": "sum(Sales[Shipping Cost])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "8ca549d0-02c9-4dc1-9b1d-919355f36a99"
          }
        ],
        "partitions": [
          {
            "name": "_Other Measures",
            "mode": "import",
            "source": {
              "expression": "Row(\"Column\", BLANK())",
              "type": "calculated"
            }
          }
        ]
