        "description": "Table containing annual targets for revenue, profit, orders and other key metrics",
        "lineageTag": "66c1f914-6114-41e6-a5d8-f7186a8670b8",
        "partitions": [
          {
            "name": "Target_Table",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Table.NestedJoin(Target_Table_Revenue, {\"Order Date - Year-Month\", \"Sub-Category\"}, Target_Table_Profit, {\"Order Date - Year-Month\", \"Sub-Category\"}, \"Target_Table_Profit\", JoinKind.Inner),",
                "    #\"Expanded Target_Table_Profit\" = Table.ExpandTableColumn(Source, \"Target_Table_Profit\", {\"Profit_Target\"}, {\"Profit_Target\"}),",
                "    #\"Merged Queries\" = Table.NestedJoin(#\"Expanded Target_Table_Profit\", {\"Order Date - Year-Month\", \"Sub-Category\"}, Target_Profit_Margin, {\"Year Month\", \"Sub-Category\"}, \"Target_Profit_Margin\", JoinKind.Inner),",
                "    #\"Expanded Target_Profit_Margin\" = Table.ExpandTableColumn(#\"Merged Queries\", \"Target_Profit_Margin\", {\"Profit Margin Target\"}, {\"Profit Margin Target\"}),",
                "    #\"Merged Queries1\" = Table.NestedJoin(#\"Expanded Target_Profit_Margin\", {\"Order Date - Year-Month\", \"Sub-Category\"}, Target_Table_Orders, {\"Year Month\", \"Sub-Category\"}, \"Target_Table_Orders\", JoinKind.Inner),",
                "    #\"Expanded Target_Table_Orders\" = Table.ExpandTableColumn(#\"Merged Queries1\", \"Target_Table_Orders\", {\"Orders_Target\"}, {\"Orders_Target\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Expanded Target_Table_Orders\",{{\"Order Date - Year-Month\", \"Date\"}}),",
                "    #\"Added Custom Column\" = Table.AddColumn(#\"Renamed Columns\", \"Custom\", each Text.Combine({Date.ToText([Date], \"yyyy\"), \"-0\", Date.ToText([Date], \"%M\")}), type text),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Added Custom Column\",{{\"Custom\", \"Year Month\"}}),",
                "    #\"Sorted Rows\" = Table.Sort(#\"Renamed Columns1\",{{\"Date\", Order.Ascending}}),",
                "    #\"Inserted Start of Month\" = Table.AddColumn(#\"Sorted Rows\", \"Start of Month\", each Date.StartOfMonth([Date]), type date),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Inserted Start of Month\",{{\"Orders_Target\", Int64.Type}}),",
                "    #\"Merged Queries2\" = Table.NestedJoin(#\"Changed Type\", {\"Date\", \"Sub-Category\"}, Target_Table_Expenses, {\"Date\", \"Sub-Category\"}, \"Target_Table_Expenses\", JoinKind.Inner),",
                "    #\"Expanded Target_Table_Expenses\" = Table.ExpandTableColumn(#\"Merged Queries2\", \"Target_Table_Expenses\", {\"TotalExpenses Target\"}, {\"TotalExpenses Target\"}),",
                "    #\"Renamed Columns2\" = Table.RenameColumns(#\"Expanded Target_Table_Expenses\",{{\"TotalExpenses Target\", \"Total Costs Target\"}, {\"Orders_Target\", \"Orders Target\"}, {\"Profit_Target\", \"Profit Target\"}, {\"Revenue_Target\", \"Revenue Target\"}})",
                "in",
                "    #\"Renamed Columns2\""
              ],
              "type": "m"
            }
          }
        ]
      },
