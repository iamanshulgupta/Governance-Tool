        "partitions": [
          {
            "name": "ClusterMappingTable",
            "mode": "import",
            "source": {
              "expression": [
                "VAR __DS0FilterTable = ",
                "\tTREATAS({2025}, 'DateTable'[Year])",
                "",
                "VAR __DS0Core = ",
                "\tSUMMARIZECOLUMNS(",
                "\t\t'Product'[Product Name],",
                "\t\t__DS0FilterTable,",
                "\t\t\"Net_Revenue\", '_Key Metrics'[Net Revenue],",
                "\t\t\"Total_Profit\", '_Key Metrics'[Total Profit],",
                "\t\t\"Orders_Count\", '_Key Metrics'[Orders Count]",
                "\t)",
                "",
                "VAR __DataTransformT0 = ",
                "\tKMeansClustering(",
                "\t\tSELECTCOLUMNS(",
                "\t\t\t__DS0Core,",
                "\t\t\t\"Product_Name\", 'Product'[Product Name],",
                "\t\t\t\"Net_Revenue\", [Net_Revenue],",
                "\t\t\t\"Total_Profit\", [Total_Profit],",
                "\t\t\t\"Orders_Count\", [Orders_Count]",
                "\t\t),",
                "\t\t{(\"[Net_Revenue]\", \"Attribute\"),",
                "\t\t\t(\"[Total_Profit]\", \"Attribute\"),",
                "\t\t\t(\"[Orders_Count]\", \"Attribute\"),",
                "\t\t\t(\"[Product_Name]\", \"Item\")},",
                "\t\t{(\"[Product_Name]\", BLANK()),",
                "\t\t\t(\"ClusterId\", \"ClusterId\")},",
                "\t\t5",
                "\t)",
                "",
                "RETURN __DataTransformT0"
              ],
              "retainDataTillForceCalculate": true,
              "type": "calculated"
            }
          }
        ]
      },
