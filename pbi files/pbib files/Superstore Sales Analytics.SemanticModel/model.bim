        "dataCategory": "Time",
        "description": "Calculated date dimension table with year, quarter, month, day and weekend columns generated via CALENDARAUTO()",
        "hierarchies": [
          {
            "name": "Date Hierarchy",
            "description": "Date Hierarchy containing Year, Quarter, Month and Day",
            "levels": [
              {
                "name": "Year",
                "column": "Year",
                "lineageTag": "0e451229-632a-416f-af4d-32832866353b",
                "ordinal": 0
              },
              {
                "name": "Quarter",
                "column": "Quarter",
                "lineageTag": "33ff4c96-4560-48dd-b50b-8eccfc731cb3",
                "ordinal": 1
              },
              {
                "name": "Day",
                "column": "Day",
                "lineageTag": "05860f83-7ae9-4df3-b3ad-2e726368025b",
                "ordinal": 3
              },
              {
                "name": "Month Name",
                "column": "Month Name",
                "lineageTag": "056856a2-3475-4405-9068-d7da01094431",
                "ordinal": 2
              }
            ],
            "lineageTag": "4fdbfd61-c6b4-44fd-ab6d-9a66ef353a9f"
          }
        ],
        "lineageTag": "d1a1dca8-976d-4f32-bad2-f1d9c04b375e",
        "partitions": [
          {
            "name": "DateTable",
            "mode": "import",
            "source": {
              "expression": [
                "",
                "VAR BaseCalendar = CALENDARAUTO()",
                "",
                "RETURN",
                "ADDCOLUMNS (",
                "    BaseCalendar,",
                "    \"Year\", YEAR([Date]),",
                "    \"Quarter\", \"Q\" & FORMAT([Date], \"Q\"),",
                "    \"Quarter Sort\", YEAR([Date]) * 10 + VALUE(FORMAT([Date], \"Q\")),",
                "    \"Month\", MONTH([Date]),",
                "    \"Month Name\", FORMAT([Date], \"MMM\"),",
                "    \"Day\", DAY([Date]),",
                "    \"Day of Week\", WEEKDAY([Date],2),",
                "    \"Day Name\", FORMAT([Date], \"DDDD\"),",
                "    \"Year Month\", FORMAT([Date], \"MMM-YYYY\"), ",
                "    \"Weekend\", IF(WEEKDAY([Date], 2) >= 6, \"Weekend\", \"Weekday\"),",
                "    \"YearMonthNum\", YEAR([Date]) * 100 + MONTH([Date])",
                ")"
              ],
              "type": "calculated"
            }
          }
        ]
      },
