          {
            "name": "Adjusted Revenue YoY %",
            "description": "Year-over-year percentage change in Adjusted Revenue compared to Net Revenue last year",
            "displayFolder": "Tariffs",
            "expression": [
              "",
              "VAR CurrentRevenue = [Adjusted Revenue]",
              "VAR PriorRevenue = CALCULATE([Net Revenue], DATEADD(DateTable[Date], -1, YEAR))",
              "RETURN",
              "IF(",
              "    NOT ISBLANK(CurrentRevenue) && ISBLANK(PriorRevenue), ",
              "    1, ",
              "    DIVIDE(CurrentRevenue - PriorRevenue, PriorRevenue)",
              ")"
            ],
