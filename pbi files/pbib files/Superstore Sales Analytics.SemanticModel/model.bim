          {
            "name": "Orders Progress V2",
            "dataCategory": "ImageUrl",
            "description": "SVG progress bar (v2 with colour coding) showing Dynamic Orders achievement vs target",
            "displayFolder": "Orders",
            "expression": [
              "",
              "VAR Actual = [Dynamic Orders]",
              "VAR Target = [Dynamic Orders Target]",
              "VAR ProgressRatio = DIVIDE(Actual, Target)",
              "",
              "",
              "VAR PERCENTAGEAXIS = MIN(ProgressRatio * 50, 100)",
              "VAR PERCENTAGETARGET = 50",
              "",
              "VAR BarColour = IF(ProgressRatio < 0.50, \"#FF4444\", IF(ProgressRatio < 1.0, \"#FFD700\", \"#4CAF50\"))",
              "VAR TextColour = \"#FFFFFF\"",
              "VAR TrackColour = \"#404040\"",
              "",
              "RETURN",
              "IF(ISINSCOPE('Product'[Sub-Category]),",
              "\"data:image/svg+xml;utf8,\" &",
              "\"<svg width='100' height='20' viewBox='0 0 100 20' xmlns='http://www.w3.org/2000/svg' display='block' overflow='visible'>",
              "<rect id='track' x='0' y='12' width='100' height='6' rx='3' fill='\" & TrackColour & \"' />",
              "<rect id='fill' x='0' y='12' width='\" & PERCENTAGEAXIS & \"' height='6' rx='3' fill='\" & BarColour & \"'></rect>",
              "<rect id='target' x='\" & PERCENTAGETARGET & \"' y='10' width='2' height='10' fill='#FFFFFF'/>",
              "<text x='0' y='8' font-size='10' font-weight='bold' font-family='Segoe UI, sans-serif' fill='\" & TextColour & \"'>\" & FORMAT(ProgressRatio, \"0%\") & \"</text>",
              "</svg>\"",
              ", BLANK())"
            ],
            "lineageTag": "fbb81dee-bbd9-4e11-befb-37a31984853d"
          },
          {
            "name": "Dynamic Total Cost",
            "description": "Total Cost filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection",
            "displayFolder": "Total Cost",
            "expression": [
              "",
              "VAR Selection = SELECTEDVALUE(TimeFilter[Period])",
              "VAR Result = ",
              "    SWITCH(",
              "        Selection,",
              "        \"YTD\", CALCULATE([Total Cost], DATESYTD(DateTable[Date])),",
              "        \"QTD\", CALCULATE([Total Cost], DATESQTD(DateTable[Date])),",
              "        \"MTD\", CALCULATE([Total Cost], DATESMTD(DateTable[Date]))",
              "    )",
              "RETURN",
              "Result"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "27435b93-fd74-47c8-8f38-50ea7f9bf319"
          },
          {
            "name": "Dynamic Total Cost Target",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ],
            "description": "Total Cost target filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection",
            "displayFolder": "Total Cost",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "RETURN",
              "SWITCH(",
              "    SelectedPeriod,",
              "    \"YTD\", CALCULATE(SUM('Target_Table'[Total Costs Target]), ",
              "                DATESYTD(DateTable[Date])),",
              "    \"QTD\", CALCULATE(SUM('Target_Table'[Total Costs Target]), ",
              "                DATESQTD(DateTable[Date])),",
              "    \"MTD\", CALCULATE(SUM('Target_Table'[Total Costs Target]), ",
              "                DATESMTD(DateTable[Date]))",
              ")"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "lineageTag": "09618731-a411-45a1-ac45-c30b3275008f"
          },
          {
            "name": "Dynamic Total Cost Target Gap",
            "description": "Difference between Dynamic Total Cost and the Dynamic Total Cost Target",
            "displayFolder": "Total Cost",
            "expression": "[Dynamic Total Cost]-[Dynamic Total Cost Target] ",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "f718e8bd-a2d6-4294-8136-1ff4e28a00a0"
          },
          {
            "name": "Total Cost Progress",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "dataCategory": "ImageUrl",
            "description": "SVG progress bar showing Dynamic Total Cost achievement vs target",
            "displayFolder": "Total Cost",
            "expression": [
              "",
              "VAR Actual = [Dynamic Total Cost]",
              "VAR Target = [Dynamic Total Cost Target]",
              "VAR ProgressRatio = DIVIDE(Actual, Target)",
              "VAR PERCENTAGEFILL = MIN(ProgressRatio * 100, 100) ",
              "",
              "",
              "VAR BarColour = \"#FFD700\" ",
              "VAR TextColour = \"#FFFFFF\" ",
              "VAR TrackColour = \"#404040\" ",
              "",
              "RETURN",
              "IF(ISINSCOPE('Subcategory'[Sub-Category]),",
              "\"data:image/svg+xml;utf8,\" & ",
              "\"<svg width='100' height='20' viewBox='0 0 100 20' xmlns='http://www.w3.org/2000/svg' display='block' overflow='visible'>",
              "<rect id='track' x='0' y='12' width='100' height='6' rx='3' fill='\" & TrackColour & \"' />",
              "<rect id='fill' x='0' y='12' width='\" & PERCENTAGEFILL & \"' height='6' rx='3' fill='\" & BarColour & \"'></rect>",
              "<text x='0' y='8' font-size='10' font-weight='bold' font-family='Segoe UI, sans-serif' fill='\" & TextColour & \"'>\" & FORMAT(ProgressRatio, \"0%\") & \"</text>",
              "</svg>\"",
              ", BLANK())"
            ],
            "lineageTag": "91cda1ac-d8f9-4c04-b175-17ede3c86e17"
          },
          {
            "name": "Total Cost YoY %",
            "description": "Year-over-year percentage change in Total Cost",
            "displayFolder": "Total Cost",
            "expression": [
              "",
              "VAR CurrentCosts = [Total Cost]",
              "VAR PriorCosts = CALCULATE([Total Cost], DATEADD(DateTable[Date], -1, YEAR))",
              "RETURN",
              "IF(",
              "    NOT ISBLANK(CurrentCosts) && ISBLANK(PriorCosts), ",
              "    1,",
              "    DIVIDE(CurrentCosts - PriorCosts, PriorCosts)",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "4d053bd3-ac41-4e60-bb2c-b53a176c7e9c"
          },
          {
            "name": "Total Cost Sparkline Monthly",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "SVG sparkline chart showing monthly trend of Total Cost",
            "displayFolder": "Total Cost",
            "expression": [
              "",
              "VAR LineColour = \"#FFD700\"",
              "VAR Pointcolour = \"#FFD700\"",
              "VAR Defs = \"<defs>",
              "    <linearGradient id='grad' x1='0' y1='0' x2='0' y2='1'>",
              "        <stop offset='0%' stop-color='#FFD700' />",
              "        <stop offset='100%' stop-color='#D3D3D3' stop-opacity='0.2' />",
              "    </linearGradient>",
              "</defs>\"",
              "",
              "",
              "VAR MonthlyTable = ",
              "    ADDCOLUMNS(",
              "        SUMMARIZE(",
              "            'DateTable',",
              "            DateTable[Year],        ",
              "            DateTable[Month], ",
              "            DateTable[MonthStart]   ",
              "        ),",
              "        \"MonthlyRevenue\", CALCULATE([Total Cost])",
              "    )",
              "",
              "",
              "",
              "VAR XMinMonth = MINX(MonthlyTable, [MonthStart])",
              "VAR XMaxMonth = MAXX(MonthlyTable, [MonthStart])",
              "VAR YMinValue = MINX(MonthlyTable, [MonthlyRevenue])",
              "VAR YMaxValue = MAXX(MonthlyTable, [MonthlyRevenue])",
              "",
              "VAR SparklineTable = ",
              "    ADDCOLUMNS(",
              "        MonthlyTable,",
              "        \"X\", INT(150 * DIVIDE([MonthStart] - XMinMonth, XMaxMonth - XMinMonth)),",
              "        \"Y\", INT(50  * DIVIDE([MonthlyRevenue] - YMinValue, YMaxValue - YMinValue))",
              "    )",
              "",
              "",
              "VAR Lines = CONCATENATEX(SparklineTable, [X] & \",\" & 50 - [Y], \" \", [MonthStart])",
              "",
              "",
              "VAR LastSparkYValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxMonth), [Y])",
              "VAR LastSparkXValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxMonth), [X])",
              "",
              "",
              "VAR SVGImageURL = ",
              "    \"data:image/svg+xml;utf8,\" & ",
              "    \"<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>\" & Defs & ",
              "    \"<polyline fill='url(#grad)' fill-opacity='0.3' stroke='transparent' stroke-width='0' points=' 0 50 \" & Lines & \" 150 150 Z '/>\" &",
              "    \"<polyline fill='transparent' stroke='\" & LineColour & \"' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' points=' \" & Lines & \" '/>\" &",
              "    \"<circle cx='\" & LastSparkXValue & \"' cy='\" & 50 - LastSparkYValue & \"' r='4' stroke='\" & LineColour & \"' stroke-width='2' fill='\" & Pointcolour & \"' />\" &",
              "    \"</svg>\"",
              "",
              "RETURN SVGImageURL"
            ],
            "lineageTag": "4a690ec9-ac99-4d5a-bffe-ed21e9e8e929"
          },
          {
            "name": "Dynamic Total Cost Target Gap with Arrow",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "description": "Dynamic Total Cost gap vs target displayed with up/down arrow indicator",
            "displayFolder": "Total Cost",
            "expression": [
              "",
              "VAR uparrow = UNICHAR(9650)",
              "VAR downarrow = UNICHAR(9660)",
              "",
              "VAR revenuegap = [Dynamic Total Cost Target Gap]",
              "",
              "RETURN",
              "IF(",
              "    revenuegap < 0,",
              "    FORMAT(revenuegap, \"$#,###\") & \" \" & downarrow,",
              "    FORMAT(revenuegap, \"$#,###\") & \" \" & uparrow",
              ")"
            ],
            "lineageTag": "a118c51d-b462-4e26-acb9-54d3071d4c57"
          },
          {
            "name": "Dynamic Total Cost YoY %",
            "description": "Year-over-year percentage change in Dynamic Total Cost using SAMEPERIODLASTYEAR",
            "displayFolder": "Total Cost",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "",
              "VAR CurrentVal = [Dynamic Total Cost]",
              "",
              "VAR PriorYearVal = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", CALCULATE([Total Cost], SAMEPERIODLASTYEAR(DATESMTD('DateTable'[Date]))),",
              "        \"QTD\", CALCULATE([Total Cost], SAMEPERIODLASTYEAR(DATESQTD('DateTable'[Date]))),",
              "        \"YTD\", CALCULATE([Total Cost], SAMEPERIODLASTYEAR(DATESYTD('DateTable'[Date])))",
              "    )",
              "",
              "RETURN",
              "DIVIDE(CurrentVal - PriorYearVal, PriorYearVal, 0)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "d8bd7032-ecc0-4c01-946d-c51dbdebf84e"
          },
          {
            "name": "Dynamic Total Cost YoY %  DATEADD",
            "description": "Year-over-year percentage change in Dynamic Total Cost using DATEADD approach",
            "displayFolder": "Total Cost",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "",
              "VAR CurrentVal = [Dynamic Total Cost]",
              "",
              "VAR PriorYearVal = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", CALCULATE([Total Cost], DATESMTD(DATEADD('DateTable'[Date], -1, YEAR))),",
              "        \"QTD\", CALCULATE([Total Cost], DATESQTD(DATEADD('DateTable'[Date], -1, YEAR))),",
              "        \"YTD\", CALCULATE([Total Cost], DATESYTD(DATEADD('DateTable'[Date], -1, YEAR)))",
              "    )",
              "",
              "RETURN",
              "DIVIDE(CurrentVal - PriorYearVal, PriorYearVal, 0)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "2639b112-ef2f-4d40-b23f-d661b510857a"
          },
