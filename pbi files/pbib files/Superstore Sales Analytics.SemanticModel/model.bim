      {
        "name": "Summary Statistics",
        "calculationGroup": {
          "calculationItems": [
            {
              "name": "Average per Order",
              "expression": [
                "",
                "IF(",
                "    ISSELECTEDMEASURE(",
                "        [Last Refreshed],",
                "        [Matrix Dynamic Title]",
                "    ),",
                "    SELECTEDMEASURE(),",
                "    IF(",
                "        ISSELECTEDMEASURE([Profit Margin %]),",
                "        DIVIDE(",
                "            SUMX(VALUES(DateTable[MonthStart]), ",
                "                CALCULATE([Net Revenue]) * CALCULATE([Profit Margin %])",
                "            ),",
                "            SUMX(VALUES(DateTable[MonthStart]), ",
                "                CALCULATE([Net Revenue])",
                "            )",
                "        ),",
                "        AVERAGEX(VALUES(Sales[Order ID]), CALCULATE((SELECTEDMEASURE())",
                "    )",
                ")))"
              ]
            },
            {
              "name": "Minimum",
              "expression": [
                "",
                "IF (",
                "    ISSELECTEDMEASURE([Last Refreshed]),",
                "    SELECTEDMEASURE(),",
                "MINX(Sales, SELECTEDMEASURE()))"
              ]
            },
            {
              "name": "Maximum",
              "expression": [
                "",
                "IF (",
                "    ISSELECTEDMEASURE(",
                "        [Last Refreshed],",
                "        [Matrix Dynamic Title]  ",
                "    ),",
                "    SELECTEDMEASURE(),",
                "    MAXX(",
                "        Sales,",
                "        CALCULATE(SELECTEDMEASURE())",
                "    )",
                ")"
              ]
            },
            {
              "name": "Current",
              "expression": [
                "",
                "    SELECTEDMEASURE()",
                ""
              ]
            },
            {
              "name": "Prior Year",
              "expression": [
                "",
                "IF (",
                "    ISSELECTEDMEASURE([Last Refreshed]),",
                "    SELECTEDMEASURE(),",
                "CALCULATE(SELECTEDMEASURE(), DATEADD('DateTable'[Date], -1, YEAR)))"
              ]
            },
            {
              "name": "Median",
              "expression": [
                "",
                "IF (",
                "    ISSELECTEDMEASURE([Last Refreshed]),",
                "    SELECTEDMEASURE(),",
                "    MEDIANX(Sales, SELECTEDMEASURE())",
                ")"
              ]
            },
            {
              "name": "Average per Item Sold",
              "expression": [
                "",
                "IF(",
                "    ISSELECTEDMEASURE(",
                "        [Last Refreshed],",
                "        [Matrix Dynamic Title]",
                "    ),",
                "    SELECTEDMEASURE(),",
                "    IF(",
                "        ISSELECTEDMEASURE([Profit Margin %]),",
                "        DIVIDE(",
                "            SUMX(VALUES(DateTable[MonthStart]), ",
                "                CALCULATE([Net Revenue]) * CALCULATE([Profit Margin %])",
                "            ),",
                "            SUMX(VALUES(DateTable[MonthStart]), ",
                "                CALCULATE([Net Revenue])",
                "            )",
                "        ),",
                "        AVERAGEX(Sales, SELECTEDMEASURE())",
                "    )",
                ")"
              ]
            }
          ]
        },
        "columns": [
          {
            "name": "Aggregation",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "isHidden": true,
            "lineageTag": "66481b86-532a-4a5b-a293-2f6baf3a6495",
