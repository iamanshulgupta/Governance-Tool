        "description": "Hidden placeholder table hosting the main key metric measures (revenue, profit, cost, orders, etc.",
        "lineageTag": "1e5b223a-05eb-4e87-8c20-b69d33bb01f7",
        "measures": [
          {
            "name": "Total Cost",
            "description": "SUM of Total Cost from Sales",
            "displayFolder": "Total Cost",
            "expression": "sum('Sales'[Total Cost])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "89a01304-4935-455f-8994-ca8cbbbb382c"
          },
          {
            "name": "Net Revenue",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              },
              {
                "name": "__PBI_SemanticLinks",
                "value": "[{\"LinkTarget\":{\"TableName\":\"Product\",\"TableItemName\":\"Product (clusters)\",\"ObjectType\":4},\"LinkType\":\"UsedInGroup\"},{\"LinkTarget\":{\"TableName\":\"Customer\",\"TableItemName\":\"City (clusters)\",\"ObjectType\":4},\"LinkType\":\"UsedInGroup\"}]"
              }
            ],
            "description": "Sum of net sales after discounts",
            "displayFolder": "Revenue",
            "expression": "sum(Sales[Net Sales])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "2466c363-4acf-4a0c-bd62-94aaa915ff49"
          },
          {
            "name": "Gross Revenue",
            "description": "Sum of gross sales before discounts",
            "displayFolder": "Revenue",
            "expression": "Sum(Sales[Gross Sales])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "4a1ac705-2d6d-4ef7-866a-506f25d8b7e4"
          },
          {
            "name": "Quantity Sold",
            "description": "Sum of quantity sold across all sales",
            "displayFolder": "Quantity",
            "expression": "sum(Sales[Quantity])",
            "formatString": "0",
            "lineageTag": "7c3daf24-55f4-420a-b913-06703e3ab46e"
          },
          {
            "name": "Total Profit",
            "annotations": [
              {
                "name": "__PBI_SemanticLinks",
                "value": "[{\"LinkTarget\":{\"TableName\":\"Product\",\"TableItemName\":\"Product (clusters)\",\"ObjectType\":4},\"LinkType\":\"UsedInGroup\"},{\"LinkTarget\":{\"TableName\":\"Customer\",\"TableItemName\":\"City (clusters)\",\"ObjectType\":4},\"LinkType\":\"UsedInGroup\"}]"
              }
            ],
            "description": "Sum of profit from the Sales table",
            "displayFolder": "Profit",
            "expression": "sum(Sales[Profit])",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "a7a76ec8-029f-4e42-bffe-7bd4b723e209"
          },
          {
            "name": "Profit Margin %",
            "description": "Net profit margin calculated as Total Profit divided by Net Revenue",
            "displayFolder": "Profit Margin %",
            "expression": "DIVIDE([Total Profit],[Net Revenue])",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "56263d22-9b67-4c37-b68f-2ceec948ca06"
          },
          {
            "name": "Dynamic Revenue YoY Growth",
            "description": "Year-over-year growth percentage of Dynamic Revenue for the selected time period",
            "displayFolder": "Revenue",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "",
              "VAR CurrentVal = [Dynamic Revenue]",
              "",
              "VAR PriorYearVal = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", CALCULATE([Net Revenue], SAMEPERIODLASTYEAR(DATESMTD('DateTable'[Date]))),",
              "        \"QTD\", CALCULATE([Net Revenue], SAMEPERIODLASTYEAR(DATESQTD('DateTable'[Date]))),",
              "        \"YTD\", CALCULATE([Net Revenue], SAMEPERIODLASTYEAR(DATESYTD('DateTable'[Date])))",
              "    )",
              "",
              "RETURN",
              "DIVIDE(CurrentVal - PriorYearVal, PriorYearVal, 0)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "f2214ee1-fd00-4b48-8c96-ece5a011e453"
          },
          {
            "name": "Orders Count",
            "annotations": [
              {
                "name": "__PBI_SemanticLinks",
                "value": "[{\"LinkTarget\":{\"TableName\":\"Product\",\"TableItemName\":\"Product (clusters)\",\"ObjectType\":4},\"LinkType\":\"UsedInGroup\"}]"
              }
            ],
            "description": "Distinct count of Order IDs",
            "displayFolder": "Orders",
            "expression": "DISTINCTCOUNT(Sales[Order ID])",
            "formatString": "0",
            "lineageTag": "69da5f85-10d8-4369-a072-e2cf70258fa5"
          },
          {
            "name": "Revenue Previous Month",
            "description": "Net Revenue for the previous month using PREVIOUSMONTH",
            "displayFolder": "Revenue",
            "expression": "CALCULATE([Net Revenue],PREVIOUSMONTH(DateTable[Date]))",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "396ab21d-fb7c-466e-8104-2a93f3f0740b"
          },
          {
            "name": "Revenue Sparkline Daily",
            "description": "SVG sparkline chart showing daily trend of Net Revenue",
            "displayFolder": "Revenue",
            "expression": [
              "VAR LineColour = \"#FFD700\"",
              "VAR Pointcolour = \"#23333333\"",
              "VAR Defs = \"<defs>",
              "    <linearGradient id='grad' x1='0' y1='0' x2='0' y2='1'>",
              "        <stop offset='0%' stop-color='#FFD700' />   // Superstore Yellow",
              "        <stop offset='100%' stop-color='#D3D3D3' stop-opacity='0.2' /> // Light Grey",
              "    </linearGradient>",
              "</defs>\"",
              "",
              "VAR XMinDate = MIN(DateTable[Date])",
              "VAR XMaxDate = MAX(DateTable[Date])",
              "",
              "",
              "VAR YMinValue = MINX(Values(DateTable[Date]),CALCULATE([Net Revenue]))",
              "VAR YMaxValue = MAXX(Values(DateTable[Date]),CALCULATE([Net Revenue]))",
              "",
              "",
              "VAR SparklineTable = ADDCOLUMNS(",
              "    SUMMARIZE('DateTable',DateTable[Date]),",
              "        \"X\",INT(150 * DIVIDE(DateTable[Date] - XMinDate, XMaxDate - XMinDate)),",
              "        \"Y\",INT(50 * DIVIDE([Net Revenue]- YMinValue,YMaxValue - YMinValue)))",
              "",
              "",
              "VAR Lines = CONCATENATEX(SparklineTable,[X] & \",\" & 50-[Y],\" \", DateTable[Date])",
              "",
              "",
              "VAR LastSparkYValue = MAXX( FILTER(SparklineTable, DateTable[Date] = XMaxDate), [Y])",
              "VAR LastSparkXValue = MAXX( FILTER(SparklineTable, DateTable[Date] = XMaxDate), [X])",
              "",
              "",
              "VAR SVGImageURL = ",
              "    \"data:image/svg+xml;utf8,\" & ",
              "    ",
              "    \"<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>\" & Defs & ",
              "     \"<polyline fill='url(#grad)' fill-opacity='0.3' stroke='transparent' ",
              "      stroke-width='0' points=' 0 50 \" & Lines & ",
              "      \" 150 150 Z '/>\" &",
              "   ",
              "    \"<polyline ",
              "        fill='transparent' stroke='\" & LineColour & \"' ",
              "        stroke-linecap='round' stroke-linejoin='round' ",
              "        stroke-width='2' points=' \" & Lines & ",
              "      \" '/>\" &",
              "    ",
              "        \"<circle cx='\"& LastSparkXValue & \"' cy='\" & 50 - LastSparkYValue & \"' r='4' stroke='\" & LineColour & \"' stroke-width='2' fill='\" & PointColour & \"' />\" &",
              "        \"</svg>\"",
              "RETURN SVGImageURL"
            ],
            "lineageTag": "1eabca69-d561-4140-ac63-4d4dbf571c49"
          },
          {
            "name": "Revenue MoM %",
            "description": "Month-over-month percentage change in Net Revenue",
            "displayFolder": "Revenue",
            "expression": [
              "",
              "VAR Revenue_PM = CALCULATE([Net Revenue], DATEADD('DateTable'[Date], -1, MONTH))",
              "RETURN",
              "DIVIDE([Net Revenue] - Revenue_PM, Revenue_PM, 0)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "68294079-8138-4bce-b524-58cfd4192388"
          },
          {
            "name": "Dynamic Revenue",
            "description": "Revenue that dynamically changes based on YTD, QTD and MTD parameter",
            "displayFolder": "Revenue",
            "expression": [
              "",
              "VAR Selection = SELECTEDVALUE(TimeFilter[Period])",
              "VAR Result = ",
              "    SWITCH(",
              "        Selection,",
              "        \"YTD\", CALCULATE([Net Revenue], DATESYTD(DateTable[Date])),",
              "        \"QTD\", CALCULATE([Net Revenue], DATESQTD(DateTable[Date])),",
              "        \"MTD\", CALCULATE([Net Revenue], DATESMTD(DateTable[Date]))",
              "    )",
              "RETURN",
              "Result"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "ed594321-8f83-4196-b3fb-9a5a59338768"
          },
          {
            "name": "Dynamic Revenue Target",
            "description": "Revenue target filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection",
            "displayFolder": "Revenue",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "RETURN",
              "SWITCH(",
              "    SelectedPeriod,",
              "    \"YTD\", CALCULATE(SUM('Target_Table'[Revenue Target]), ",
              "                DATESYTD(DateTable[Date])),",
              "    \"QTD\", CALCULATE(SUM('Target_Table'[Revenue Target]), ",
              "                DATESQTD(DateTable[Date])),",
              "    \"MTD\", CALCULATE(SUM('Target_Table'[Revenue Target]), ",
              "                DATESMTD(DateTable[Date]))",
              ")"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "6115e761-b735-483e-b3cc-934d10291736"
          },
          {
            "name": "Dynamic Revenue Target Gap with Arrow",
            "description": "Dynamic Revenue gap vs target displayed with up/down arrow indicator",
            "displayFolder": "Revenue",
            "expression": [
              "",
              "VAR uparrow = UNICHAR(9650)",
              "VAR downarrow = UNICHAR(9660)",
              "",
              "VAR revenuegap = [Dynamic Revenue Target Gap]",
              "",
              "RETURN",
              "IF(",
              "    revenuegap < 0,",
              "    FORMAT(revenuegap, \"$#,###\") & \" \" & downarrow,",
              "    FORMAT(revenuegap, \"$#,###\") & \" \" & uparrow",
              ")"
            ],
            "lineageTag": "94864351-dd01-484d-b27d-f1a4d3351eaf"
          },
          {
            "name": "Dynamic Revenue Target Gap",
            "description": "Difference between Dynamic Revenue and the Dynamic Revenue Target",
            "displayFolder": "Revenue",
            "expression": "[Dynamic Revenue]-[Dynamic Revenue Target] ",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "18e9b0bd-8881-4f87-a4ee-618254c27ebf"
          },
          {
            "name": "Dynamic Profit",
            "description": "Total Profit filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection",
            "displayFolder": "Profit",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "RETURN",
              "SWITCH( SelectedPeriod,",
              "    \"MTD\", TOTALMTD([Total Profit], 'DateTable'[Date]),",
              "    \"QTD\", TOTALQTD([Total Profit], 'DateTable'[Date]),",
              "    \"YTD\", TOTALYTD([Total Profit], 'DateTable'[Date])",
              ")"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "70c7e928-4523-4d48-bf37-0bf49e35ae47"
          },
          {
            "name": "Dynamic Profit Target",
            "description": "Profit target filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection",
            "displayFolder": "Profit",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "RETURN",
              "SWITCH(",
              "    SelectedPeriod,",
              "    \"YTD\", CALCULATE(SUM('Target_Table'[Profit Target]), ",
              "                DATESYTD(DateTable[Date])),",
              "    \"QTD\", CALCULATE(SUM('Target_Table'[Profit Target]), ",
              "                DATESQTD(DateTable[Date])),",
              "    \"MTD\", CALCULATE(SUM('Target_Table'[Profit Target]), ",
              "                DATESMTD(DateTable[Date]))",
              ")"
            ],
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "5edaa411-bbdc-4b58-8ad4-21bcfeee2ac5"
          },
          {
            "name": "Dynamic Profit Target Gap",
            "description": "Difference between Dynamic Profit and the Dynamic Profit Target",
            "displayFolder": "Profit",
            "expression": "[Dynamic Profit]-[Dynamic Profit Target] ",
            "formatString": "\\$#,0;(\\$#,0);\\$#,0",
            "lineageTag": "2e4a7be9-b110-4a3e-b7cb-8ef357e54c97"
          },
          {
            "name": "Dynamic Profit Target Gap with Arrow",
            "description": "Dynamic Profit gap vs target displayed with up/down arrow indicator",
            "displayFolder": "Profit",
            "expression": [
              "",
              "VAR uparrow = UNICHAR(9650)",
              "VAR downarrow = UNICHAR(9660)",
              "",
              "VAR profitgap = [Dynamic Profit Target Gap]",
              "",
              "RETURN",
              "IF(",
              "    profitgap < 0,",
              "    FORMAT(profitgap, \"$#,###\") & \" \" & downarrow,",
              "    FORMAT(profitgap, \"$#,###\") & \" \" & uparrow",
              ")"
            ],
            "lineageTag": "f88cf47e-6a76-41b1-8718-5a8abf549bf4"
          },
          {
            "name": "Dynamic Profit Margin %",
            "description": "Profit Margin % calculated dynamically for the selected YTD, QTD, or MTD period",
            "displayFolder": "Profit Margin %",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "",
              "VAR PeriodProfit = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", TOTALMTD([Total Profit], 'DateTable'[Date]),",
              "        \"QTD\", TOTALQTD([Total Profit], 'DateTable'[Date]),",
              "        \"YTD\", TOTALYTD([Total Profit], 'DateTable'[Date])",
              "    )",
              "",
              "VAR PeriodRevenue = ",
              "    SWITCH( SelectedPeriod,",
              "        \"MTD\", TOTALMTD([Net Revenue], 'DateTable'[Date]),",
              "        \"QTD\", TOTALQTD([Net Revenue], 'DateTable'[Date]),",
              "        \"YTD\", TOTALYTD([Net Revenue], 'DateTable'[Date])",
              "    )",
              "",
              "RETURN",
              "DIVIDE(PeriodProfit, PeriodRevenue)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "84ea06bc-36f1-442b-9185-eedb1f4d80c5"
          },
          {
            "name": "Dynamic Profit Margin % Target",
            "description": "Profit Margin % target filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection",
            "displayFolder": "Profit Margin %",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "RETURN",
              "SWITCH(",
              "    SelectedPeriod,",
              "    \"YTD\", CALCULATE(AVERAGE('Target_Table'[Profit Margin Target]), ",
              "                DATESYTD(DateTable[Date])),",
              "    \"QTD\", CALCULATE(AVERAGE('Target_Table'[Profit Margin Target]), ",
              "                DATESQTD(DateTable[Date])),",
              "    \"MTD\", CALCULATE(AVERAGE('Target_Table'[Profit Margin Target]), ",
              "                DATESMTD(DateTable[Date]))",
              ")",
              ""
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "8aa586d4-8cd7-4b92-889a-3b15d1850344"
          },
          {
            "name": "Dynamic Profit Margin % Target Gap with Arrow",
            "description": "Dynamic Profit Margin % gap vs target displayed with up/down arrow indicator",
            "displayFolder": "Profit Margin %",
            "expression": [
              "",
              "VAR uparrow = UNICHAR(9650)",
              "VAR downarrow = UNICHAR(9660)",
              "VAR square = UNICHAR(9209)",
              "",
              "VAR profitmargingap = [Dynamic Profit Margin %] - [Dynamic Profit Margin % Target]",
              "",
              "RETURN",
              "IF(",
              "    profitmargingap < 0,",
              "    FORMAT(profitmargingap, \"0.00 %\") & \" \" & downarrow,",
              "    FORMAT(profitmargingap, \"0.00 %\") & \" \" & uparrow",
              ")"
            ],
            "lineageTag": "12dc8ecf-cda1-4407-ad99-fabc746a6f6a"
          },
          {
            "name": "Dynamic Profit Margin % Target Gap",
            "description": "Difference between Dynamic Profit Margin % and its target for the selected period",
            "displayFolder": "Profit Margin %",
            "expression": "[Dynamic Profit Margin %]-[Dynamic Profit Margin % Target] ",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "42c04d8f-965b-4aae-a4f5-50de41b18a14"
          },
          {
            "name": "Dynamic Orders",
            "description": "Order count filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection",
            "displayFolder": "Orders",
            "expression": [
              "",
              "VAR Selection = SELECTEDVALUE(TimeFilter[Period])",
              "RETURN",
              "SWITCH(",
              "    Selection,",
              "",
              "    \"YTD\",",
              "        CALCULATE(",
              "            DISTINCTCOUNT(Sales[Order ID]),",
              "            DATESYTD(DateTable[Date])",
              "        ),",
              "",
              "    \"QTD\",",
              "        CALCULATE(",
              "            DISTINCTCOUNT(Sales[Order ID]),",
              "            DATESQTD(DateTable[Date])",
              "        ),",
              "",
              "    \"MTD\",",
              "        CALCULATE(",
              "            DISTINCTCOUNT(Sales[Order ID]),",
              "            DATESMTD(DateTable[Date])",
              "        ),",
              "",
              "    DISTINCTCOUNT(Sales[Order ID])",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "471af660-b7c7-470e-8493-9a473f36f5e9"
          },
          {
            "name": "Dynamic Orders Target",
            "description": "Orders target filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection",
            "displayFolder": "Orders",
            "expression": [
              "",
              "VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], \"YTD\")",
              "RETURN",
              "SWITCH(",
              "    SelectedPeriod,",
              "    \"YTD\", CALCULATE(SUM('Target_Table'[Orders Target]), ",
              "                DATESYTD(DateTable[Date])),",
              "    \"QTD\", CALCULATE(SUM('Target_Table'[Orders Target]), ",
              "                DATESQTD(DateTable[Date])),",
              "    \"MTD\", CALCULATE(SUM('Target_Table'[Orders Target]), ",
              "                DATESMTD(DateTable[Date]))",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "4a0ccc63-345b-4589-8997-ab03b4847ffc"
          },
          {
            "name": "Dynamic Orders Target Gap",
