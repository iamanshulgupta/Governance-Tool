		/// Adjusted Profit gap vs target displayed with up/down arrow indicator
		measure 'Adjusted Profit Target Gap with Arrow' =
				
				VAR uparrow = UNICHAR(9650)
				VAR downarrow = UNICHAR(9660)
				
				VAR profitgap = [Adjusted Profit Target Gap]
				
				RETURN
				IF(
