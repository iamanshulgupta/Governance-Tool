	ref table '_Other Measures'

		/// Average cost per unit across all products using MAX cost per unit per product name
		measure 'AVG Cost per Product' = AVERAGEX(VALUES('Product'[Product Name]), CALCULATE(MAX('Sales'[Cost per Unit])))
