	ref table Customer

		/// Display label combining the active Scenario Tariff Rate and Price Increase Rate
		measure 'Active Tariff Rate' =
				
				"Tariff: " & [Scenario Tariff Rate] & "% | Price Increase: " & [Scenario Price Increase] & "%"
			displayFolder: Tariffs
			lineageTag: 926c2824-7880-40a6-a235-07fb838818cf

			changedProperty = IsHidden

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		/// Total Cost adjusted upward by the Scenario Tariff Rate
		measure 'Adjusted Cost' = [Total Cost] * (1 + DIVIDE([Scenario Tariff Rate], 100))
			formatString: \$#,0;(\$#,0);\$#,0
