		/// Average price per unit across all products using MAX price per unit per product name
		measure 'AVG Price per Product' = AVERAGEX(VALUES('Product'[Product Name]), CALCULATE(MAX('Sales'[Price per Unit])))
			formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
			lineageTag: cd5ff50d-f69e-4223-8ddc-80a1bc42bb4e

		/// Average Order Value by city calculated as Net Revenue divided by Orders Count
		measure 'City AOV' = ```
