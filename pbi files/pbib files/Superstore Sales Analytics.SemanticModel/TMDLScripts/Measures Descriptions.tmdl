		/// Adjusted Revenue minus Adjusted Cost under the active tariff scenario
		measure 'Adjusted Profit' = [Adjusted Revenue] - [Adjusted Cost]
			formatString: \$#,0;(\$#,0);\$#,0
			displayFolder: Tariff Analysis
			lineageTag: 3698263b-5fa3-444e-824a-832985b58732

