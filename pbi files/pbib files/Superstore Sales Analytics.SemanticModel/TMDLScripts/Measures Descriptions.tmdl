		/// Value used in waterfall chart showing Baseline Profit, Tariff Impact, and Price Increase Benefit
		measure 'Waterfall Value' =
				
				SWITCH(
				    SELECTEDVALUE(WaterfallSteps[Metric]),
				    "Baseline Profit", [Total Profit],
				    "Tariff Impact", -[Tariff Impact],
				    "Price Increase Benefit", [Adjusted Revenue] - [Net Revenue]
				)
			displayFolder: Tariff Analysis
			lineageTag: c1fea4ba-1c54-4a67-8a68-8a29a96aedba

			changedProperty = IsHidden

			annotation PBI_FormatHint = {"isGeneralNumber":true}

