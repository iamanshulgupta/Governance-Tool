		/// Adjusted Profit divided by Adjusted Revenue under the active tariff scenario
		measure 'Adjusted Profit Margin %' = DIVIDE([Adjusted Profit], [Adjusted Revenue],0)
			formatString: 0.00%;-0.00%;0.00%
			displayFolder: Tariff Analysis
			lineageTag: a6c4667d-2414-4eaa-870c-4d768165fdd4

			changedProperty = IsHidden

		/// Revenue adjusted for Price Increase Rate
		measure 'Adjusted Revenue' = [Net Revenue] * (1 + DIVIDE([Scenario Price Increase], 100))
			formatString: 0
			displayFolder: Tariff Analysis
			lineageTag: 20ad7789-7518-48b8-b4b9-f10f11e6ecfd

			changedProperty = IsHidden

			annotation PBI_FormatHint = {"isDecimal":true}

		/// SVG sparkline chart showing monthly trend of Adjusted Cost
		measure 'Adjusted Total Cost Sparkline Monthly' = ```
				
				VAR LineColour = "#FFD700"
				VAR Pointcolour = "#FFD700"
				VAR Defs = "<defs>
				    <linearGradient id='grad' x1='0' y1='0' x2='0' y2='1'>
				        <stop offset='0%' stop-color='#FFD700' />
				        <stop offset='100%' stop-color='#D3D3D3' stop-opacity='0.2' />
				    </linearGradient>
				</defs>"
				
				VAR MonthlyTable = 
				    ADDCOLUMNS(
				        SUMMARIZE(
				            'DateTable',
				            DateTable[Year],        
				            DateTable[Month], 
				            DateTable[MonthStart]    
				        ),
				        "MonthlyRevenue", CALCULATE([Adjusted Cost])
				    )
				
				VAR XMinMonth = MINX(MonthlyTable, [MonthStart])
				VAR XMaxMonth = MAXX(MonthlyTable, [MonthStart])
				VAR YMinValue = MINX(MonthlyTable, [MonthlyRevenue])
				VAR YMaxValue = MAXX(MonthlyTable, [MonthlyRevenue])
				
				VAR SparklineTable = 
				    ADDCOLUMNS(
				        MonthlyTable,
				        "X", INT(150 * DIVIDE([MonthStart] - XMinMonth, XMaxMonth - XMinMonth)),
				        "Y", INT(50  * DIVIDE([MonthlyRevenue] - YMinValue, YMaxValue - YMinValue))
				    )
				
				VAR Lines = CONCATENATEX(SparklineTable, [X] & "," & 50 - [Y], " ", [MonthStart])
				
				VAR LastSparkYValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxMonth), [Y])
				VAR LastSparkXValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxMonth), [X])
				
				VAR SVGImageURL = 
				    "data:image/svg+xml;utf8," & 
				    "<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>" & Defs & 
				    "<polyline fill='url(#grad)' fill-opacity='0.3' stroke='transparent' stroke-width='0' points=' 0 50 " & Lines & " 150 150 Z '/>" &
				    "<polyline fill='transparent' stroke='" & LineColour & "' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' points=' " & Lines & " '/>" &
				    "<circle cx='" & LastSparkXValue & "' cy='" & 50 - LastSparkYValue & "' r='4' stroke='" & LineColour & "' stroke-width='2' fill='" & Pointcolour & "' />" &
				    "</svg>"
				
				RETURN SVGImageURL
				```
			displayFolder: Tariffs
			lineageTag: 467a73e7-c84d-4437-8d20-bbb146a8717f
			dataCategory: ImageUrl

			changedProperty = IsHidden

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		/// Selected price increase percentage from the Scenarios table, defaulting to the Price Increase Rate Value
		measure 'Scenario Price Increase' =
				
				SELECTEDVALUE(Scenarios[Price Increase], [Price Increase Rate Value])
			displayFolder: Tariffs
			lineageTag: 2b984570-b4e3-4d13-8360-be5277cf4f19

			changedProperty = IsHidden

