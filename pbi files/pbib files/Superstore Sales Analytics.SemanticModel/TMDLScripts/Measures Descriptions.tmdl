		/// Calculates Revenue Target Gap with Arrow
		measure 'Revenue Target Gap with Arrow' =
				
				VAR uparrow = UNICHAR(9650)
				VAR downarrow = UNICHAR(9660)
				
				VAR revenuegap = [Revenue Target Gap]
				
				RETURN
				IF(
				    revenuegap < 0,
				    FORMAT(revenuegap, "$#,###") & " " & downarrow,
				    FORMAT(revenuegap, "$#,###") & " " & uparrow
				)
