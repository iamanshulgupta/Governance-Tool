		/// Dynamic Profit Margin % gap vs target displayed with up/down arrow indicator
		measure 'Dynamic Profit Margin % Target Gap with Arrow' =
				
				VAR uparrow = UNICHAR(9650)
				VAR downarrow = UNICHAR(9660)
				VAR square = UNICHAR(9209)
				
				VAR profitmargingap = [Dynamic Profit Margin %] - [Dynamic Profit Margin % Target]
				
