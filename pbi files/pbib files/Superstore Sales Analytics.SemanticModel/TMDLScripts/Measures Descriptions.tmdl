		/// Order count filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection
		measure 'Dynamic Orders' =
				
				VAR Selection = SELECTEDVALUE(TimeFilter[Period])
				RETURN
				SWITCH(
				    Selection,
				
				    "YTD",
				        CALCULATE(
				            DISTINCTCOUNT(Sales[Order ID]),
				            DATESYTD(DateTable[Date])
				        ),
				
				    "QTD",
				        CALCULATE(
				            DISTINCTCOUNT(Sales[Order ID]),
				            DATESQTD(DateTable[Date])
				        ),
				
				    "MTD",
				        CALCULATE(
				            DISTINCTCOUNT(Sales[Order ID]),
				            DATESMTD(DateTable[Date])
				        ),
				
				    DISTINCTCOUNT(Sales[Order ID])
				)
			formatString: 0
			displayFolder: Orders
			lineageTag: 471af660-b7c7-470e-8493-9a473f36f5e9

		/// Orders target filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection
		measure 'Dynamic Orders Target' = ```
				
				VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], "YTD")
				RETURN
				SWITCH(
				    SelectedPeriod,
				    "YTD", CALCULATE(SUM('Target_Table'[Orders Target]), 
				                DATESYTD(DateTable[Date])),
				    "QTD", CALCULATE(SUM('Target_Table'[Orders Target]), 
				                DATESQTD(DateTable[Date])),
				    "MTD", CALCULATE(SUM('Target_Table'[Orders Target]), 
				                DATESMTD(DateTable[Date]))
				)
				```
			formatString: 0
			displayFolder: Orders
			lineageTag: 4a0ccc63-345b-4589-8997-ab03b4847ffc

		/// Difference between Dynamic Orders and the Dynamic Orders Target
		measure 'Dynamic Orders Target Gap' = ```
				[Dynamic Orders]-[Dynamic Orders Target] 
				```
			formatString: 0
			displayFolder: Orders
			lineageTag: 703f5bfc-00b1-4846-8ba0-3ecede8c2d85

		/// Dynamic Orders gap vs target displayed with up/down arrow indicator
		measure 'Dynamic Orders Target Gap with Arrow' =
				
				VAR uparrow = UNICHAR(9650)
				VAR downarrow = UNICHAR(9660)
				
				VAR ordersgap = [Dynamic Orders Target Gap]
				
				RETURN
				IF(
				    ordersgap < 0,
				    FORMAT(ordersgap, "#") & " " & downarrow,
				    FORMAT(ordersgap, "#") & " " & uparrow
				)
			displayFolder: Orders
			lineageTag: 539c5c56-71bf-4757-a820-37fbe244337d

		/// Year-over-year growth percentage of Dynamic Orders for the selected time period
		measure 'Dynamic Orders YoY Growth' = ```
				
				VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], "YTD")
				
				VAR CurrentVal = [Dynamic Orders]
				
				VAR PriorYearVal = 
				    SWITCH( SelectedPeriod,
				        "MTD", CALCULATE([Dynamic Orders], SAMEPERIODLASTYEAR(DATESMTD('DateTable'[Date]))),
				        "QTD", CALCULATE([Dynamic Orders], SAMEPERIODLASTYEAR(DATESQTD('DateTable'[Date]))),
				        "YTD", CALCULATE([Dynamic Orders], SAMEPERIODLASTYEAR(DATESYTD('DateTable'[Date])))
				    )
				
				RETURN
				DIVIDE(CurrentVal - PriorYearVal, PriorYearVal, 0)
				```
			formatString: 0.00%;-0.00%;0.00%
			displayFolder: Orders
			lineageTag: df938a86-6c4f-42b8-9efa-3cf67f42e064

		/// Total Profit filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection
		measure 'Dynamic Profit' =
				
				VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], "YTD")
				RETURN
				SWITCH( SelectedPeriod,
				    "MTD", TOTALMTD([Total Profit], 'DateTable'[Date]),
				    "QTD", TOTALQTD([Total Profit], 'DateTable'[Date]),
				    "YTD", TOTALYTD([Total Profit], 'DateTable'[Date])
				)
			formatString: \$#,0;(\$#,0);\$#,0
			displayFolder: Profit
			lineageTag: 70c7e928-4523-4d48-bf37-0bf49e35ae47

		/// Profit Margin % calculated dynamically for the selected YTD, QTD, or MTD period
		measure 'Dynamic Profit Margin %' = ```
				
				VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], "YTD")
				
				VAR PeriodProfit = 
				    SWITCH( SelectedPeriod,
				        "MTD", TOTALMTD([Total Profit], 'DateTable'[Date]),
				        "QTD", TOTALQTD([Total Profit], 'DateTable'[Date]),
				        "YTD", TOTALYTD([Total Profit], 'DateTable'[Date])
				    )
				
				VAR PeriodRevenue = 
				    SWITCH( SelectedPeriod,
				        "MTD", TOTALMTD([Net Revenue], 'DateTable'[Date]),
				        "QTD", TOTALQTD([Net Revenue], 'DateTable'[Date]),
				        "YTD", TOTALYTD([Net Revenue], 'DateTable'[Date])
				    )
				
				RETURN
				DIVIDE(PeriodProfit, PeriodRevenue)
				```
			formatString: 0.00%;-0.00%;0.00%
			displayFolder: Profit Margin %
			lineageTag: 84ea06bc-36f1-442b-9185-eedb1f4d80c5

		/// Profit Margin % target filtered dynamically by YTD, QTD, or MTD based on TimeFilter selection
		measure 'Dynamic Profit Margin % Target' = ```
				
				VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], "YTD")
				RETURN
				SWITCH(
				    SelectedPeriod,
				    "YTD", CALCULATE(AVERAGE('Target_Table'[Profit Margin Target]), 
				                DATESYTD(DateTable[Date])),
				    "QTD", CALCULATE(AVERAGE('Target_Table'[Profit Margin Target]), 
				                DATESQTD(DateTable[Date])),
				    "MTD", CALCULATE(AVERAGE('Target_Table'[Profit Margin Target]), 
				                DATESMTD(DateTable[Date]))
				)
				
				```
			formatString: 0.00%;-0.00%;0.00%
			displayFolder: Profit Margin %
			lineageTag: 8aa586d4-8cd7-4b92-889a-3b15d1850344

		/// Difference between Dynamic Profit Margin % and its target for the selected period
		measure 'Dynamic Profit Margin % Target Gap' = ```
				[Dynamic Profit Margin %]-[Dynamic Profit Margin % Target] 
				```
			formatString: 0.00%;-0.00%;0.00%
