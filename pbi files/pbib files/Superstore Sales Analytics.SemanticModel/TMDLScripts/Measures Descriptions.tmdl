				VAR LastSparkYValue = MAXX( FILTER(SparklineTable, DateTable[Date] = XMaxDate), [Y])
				VAR LastSparkXValue = MAXX( FILTER(SparklineTable, DateTable[Date] = XMaxDate), [X])
				
				
				VAR SVGImageURL = 
				    "data:image/svg+xml;utf8," & 
				    
				    "<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>" & Defs & 
