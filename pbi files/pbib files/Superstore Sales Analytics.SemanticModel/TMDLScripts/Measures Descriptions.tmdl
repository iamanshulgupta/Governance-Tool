		/// Distinct count of Order IDs
		measure 'Orders Count' = DISTINCTCOUNT(Sales[Order ID])
			formatString: 0
			displayFolder: Orders
			lineageTag: 69da5f85-10d8-4369-a072-e2cf70258fa5

		/// SVG sparkline chart showing monthly trend of Orders Count
		measure 'Orders Count Sparkline Monthly' = ```
				
				VAR LineColour = "#FFD700"
				VAR Pointcolour = "#FFD700"
				VAR Defs = "<defs>
				    <linearGradient id='grad' x1='0' y1='0' x2='0' y2='1'>
				        <stop offset='0%' stop-color='#FFD700' />
				        <stop offset='100%' stop-color='#D3D3D3' stop-opacity='0.2' />
				    </linearGradient>
				</defs>"
				
				VAR MonthlyTable =
				    ADDCOLUMNS(
				        SUMMARIZE(
				            'DateTable',
				            DateTable[Year],
				            DateTable[Month]
				        ),
				        "MonthStart", DATE(DateTable[Year], DateTable[Month], 1),
				        "MonthlyOrdersCount", CALCULATE([Orders Count])
				    )
				
				VAR XMinDate = MINX(MonthlyTable, [MonthStart])
				VAR XMaxDate = MAXX(MonthlyTable, [MonthStart])
				VAR YMinValue = MINX(MonthlyTable, [MonthlyOrdersCount])
				VAR YMaxValue = MAXX(MonthlyTable, [MonthlyOrdersCount])
				
				VAR SparklineTable =
				    ADDCOLUMNS(
				        MonthlyTable,
				        "X", INT(150 * DIVIDE([MonthStart] - XMinDate, XMaxDate - XMinDate)),
				        "Y", INT(50 * DIVIDE([MonthlyOrdersCount] - YMinValue, YMaxValue - YMinValue))
				    )
				
				VAR Lines = CONCATENATEX(SparklineTable, [X] & "," & 50 - [Y], " ", [MonthStart])
				
				VAR LastSparkYValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxDate), [Y])
				VAR LastSparkXValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxDate), [X])
				
				VAR SVGImageURL = 
				    "data:image/svg+xml;utf8," & 
				    "<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>" & Defs & 
				    "<polyline fill='url(#grad)' fill-opacity='0.3' stroke='transparent' 
				     stroke-width='0' points=' 0 50 " & Lines & 
				     " 150 150 Z '/>" &
				    "<polyline 
				        fill='transparent' stroke='" & LineColour & "' 
				        stroke-linecap='round' stroke-linejoin='round' 
				        stroke-width='2' points=' " & Lines & 
				     " '/>" &
				    "<circle cx='" & LastSparkXValue & "' cy='" & 50 - LastSparkYValue & "' r='4' stroke='" & LineColour & "' stroke-width='2' fill='" & Pointcolour & "' />" &
				    "</svg>"
				
				RETURN SVGImageURL
				```
			displayFolder: Orders
			lineageTag: 883a3080-87a3-4b3b-9d65-27e762a6be71

		/// SVG progress bar showing Dynamic Orders achievement vs target by sub-category
		measure 'Orders Progress' = ```
				
				VAR Actual = [Dynamic Orders]
				VAR Target = [Dynamic Orders Target]
				VAR ProgressRatio = DIVIDE(Actual, Target)
				VAR PERCENTAGEFILL = MIN(ProgressRatio*100, 100) 
				
				
				VAR BarColour = "#FFD700" 
				VAR TextColour = "#FFFFFF" 
				VAR TrackColour = "#404040"
				
				RETURN
				IF(ISINSCOPE('Subcategory'[Sub-Category]),
				"data:image/svg+xml;utf8," & 
				"<svg width='100' height='20' viewBox='0 0 100 20' xmlns='http://www.w3.org/2000/svg' display='block' overflow='visible'>
				<rect id='track' x='0' y='12' width='100' height='6' rx='3' fill='" & TrackColour & "' />
				<rect id='fill' x='0' y='12' width='" & PERCENTAGEFILL & "' height='6' rx='3' fill='" & BarColour & "'></rect>
				<text x='0' y='8' font-size='10' font-weight='bold' font-family='Segoe UI, sans-serif' fill='" & TextColour & "'>" & FORMAT(ProgressRatio, "0%") & "</text>
				</svg>"
				, BLANK())
				```
			displayFolder: Orders
			lineageTag: a7d2e9a8-7e70-4abf-9c97-823892813d52
			dataCategory: ImageUrl

		/// SVG progress bar (v2 with colour coding) showing Dynamic Orders achievement vs target
		measure 'Orders Progress V2' =
				
				VAR Actual = [Dynamic Orders]
				VAR Target = [Dynamic Orders Target]
				VAR ProgressRatio = DIVIDE(Actual, Target)
				
				
				VAR PERCENTAGEAXIS = MIN(ProgressRatio * 50, 100)
				VAR PERCENTAGETARGET = 50
				
				VAR BarColour = IF(ProgressRatio < 0.50, "#FF4444", IF(ProgressRatio < 1.0, "#FFD700", "#4CAF50"))
				VAR TextColour = "#FFFFFF"
				VAR TrackColour = "#404040"
				
				RETURN
				IF(ISINSCOPE('Product'[Sub-Category]),
				"data:image/svg+xml;utf8," &
				"<svg width='100' height='20' viewBox='0 0 100 20' xmlns='http://www.w3.org/2000/svg' display='block' overflow='visible'>
				<rect id='track' x='0' y='12' width='100' height='6' rx='3' fill='" & TrackColour & "' />
				<rect id='fill' x='0' y='12' width='" & PERCENTAGEAXIS & "' height='6' rx='3' fill='" & BarColour & "'></rect>
				<rect id='target' x='" & PERCENTAGETARGET & "' y='10' width='2' height='10' fill='#FFFFFF'/>
				<text x='0' y='8' font-size='10' font-weight='bold' font-family='Segoe UI, sans-serif' fill='" & TextColour & "'>" & FORMAT(ProgressRatio, "0%") & "</text>
				</svg>"
				, BLANK())
			displayFolder: Orders
			lineageTag: fbb81dee-bbd9-4e11-befb-37a31984853d
			dataCategory: ImageUrl

