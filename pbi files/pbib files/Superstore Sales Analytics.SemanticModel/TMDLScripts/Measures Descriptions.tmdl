		/// Year-over-year growth percentage of Dynamic Profit Margin % for the selected time period
		measure 'Dynamic Profit Margin YoY Growth' = ```
				
				VAR SelectedPeriod = SELECTEDVALUE(TimeFilter[Period], "YTD")
				
				VAR CurrentMargin = [Dynamic Profit Margin %]
				
				VAR PriorYearMargin = 
				    SWITCH( SelectedPeriod,
				        "MTD", CALCULATE([Profit Margin %], SAMEPERIODLASTYEAR(DATESMTD('DateTable'[Date]))),
				        "QTD", CALCULATE([Profit Margin %], SAMEPERIODLASTYEAR(DATESQTD('DateTable'[Date]))),
				        "YTD", CALCULATE([Profit Margin %], SAMEPERIODLASTYEAR(DATESYTD('DateTable'[Date])))
				    )
				
				RETURN
				CurrentMargin - PriorYearMargin
				```
			formatString: 0.00%;-0.00%;0.00%
			displayFolder: Profit Margin %
