		/// SVG progress bar showing Dynamic Revenue achievement vs target by sub-category
		measure 'Revenue Progress' = ```
				
				VAR Actual = [Dynamic Revenue]
				VAR Target = [Dynamic Revenue Target]
				VAR ProgressRatio = DIVIDE(Actual, Target)
				VAR PERCENTAGEFILL = MIN(ProgressRatio * 100, 100) 
				
				VAR BarColour = "#FFD700" 
				VAR TextColour = "#FFFFFF" 
				VAR TrackColour = "#404040" 
				
				RETURN
				IF(ISINSCOPE('Subcategory'[Sub-Category]),
				"data:image/svg+xml;utf8," & 
				"<svg width='100' height='20' viewBox='0 0 100 20' xmlns='http://www.w3.org/2000/svg' display='block' overflow='visible'>
				<rect id='track' x='0' y='12' width='100' height='6' rx='3' fill='" & TrackColour & "' />
				<rect id='fill' x='0' y='12' width='" & PERCENTAGEFILL & "' height='6' rx='3' fill='" & BarColour & "'></rect>
				<text x='0' y='8' font-size='10' font-weight='bold' font-family='Segoe UI, sans-serif' fill='" & TextColour & "'>" & FORMAT(ProgressRatio, "0%") & "</text>
				</svg>"
				, BLANK())
				```
			displayFolder: Revenue
			lineageTag: 85df5b53-dc2b-4a92-930e-9783a5838c9e
			dataCategory: ImageUrl

