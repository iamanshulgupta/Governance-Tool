createOrReplace

	ref table '_Key Metrics'

		/// Year-over-year percentage change in Adjusted Revenue compared to the same period last year
		measure 'Adjussted Revenue YoY %' = ```
				
				VAR CurrentRevenue = [Adjusted Revenue]
				VAR PriorRevenue = CALCULATE([Adjusted Revenue], DATEADD(DateTable[Date], -1, YEAR))
				RETURN
				IF(
				    NOT ISBLANK(CurrentRevenue) && ISBLANK(PriorRevenue), 
				    1, 
				    DIVIDE(CurrentRevenue - PriorRevenue, PriorRevenue)
				)
				```
			formatString: 0.00%
			displayFolder: Tariffs
			lineageTag: f5b1d4c0-c857-47dc-8f1e-f9dc2ddbd894

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		/// SVG sparkline chart showing monthly trend of Adjusted Profit Margin %
		measure 'Adjusted Profit Margin % Sparkline Monthly' = ```
				
				VAR LineColour = "#FFD700"
				VAR Pointcolour = "#FFD700"
				VAR Defs = "<defs>
				    <linearGradient id='grad' x1='0' y1='0' x2='0' y2='1'>
				        <stop offset='0%' stop-color='#FFD700' />
				        <stop offset='100%' stop-color='#D3D3D3' stop-opacity='0.2' />
				    </linearGradient>
				</defs>"
				
				VAR MonthlyTable =
				    ADDCOLUMNS(
				        SUMMARIZE('DateTable', DateTable[Year], DateTable[Month]),
				        "MonthStart", DATE(DateTable[Year], DateTable[Month], 1),
				        "MonthlyProfit", CALCULATE([Adjusted Profit]),
				        "MonthlyRevenue", CALCULATE([Adjusted Revenue])
				    )
				
				VAR XMinDate = MINX(MonthlyTable, [MonthStart])
				VAR XMaxDate = MAXX(MonthlyTable, [MonthStart])
				VAR YMinValue = MINX(MonthlyTable, DIVIDE([MonthlyProfit], [MonthlyRevenue]))
				VAR YMaxValue = MAXX(MonthlyTable, DIVIDE([MonthlyProfit], [MonthlyRevenue]))
				
				VAR SparklineTable =
				    ADDCOLUMNS(
				        MonthlyTable,
				        "MonthlyProfitMargin", DIVIDE([MonthlyProfit], [MonthlyRevenue]),
				        "X", INT(150 * DIVIDE([MonthStart] - XMinDate, XMaxDate - XMinDate)),
				        "Y", INT(50 * DIVIDE(DIVIDE([MonthlyProfit], [MonthlyRevenue]) - YMinValue, YMaxValue - YMinValue))
				    )
				
				VAR Lines = CONCATENATEX(SparklineTable, [X] & "," & 50 - [Y], " ", [MonthStart])
				
				VAR LastSparkYValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxDate), [Y])
				VAR LastSparkXValue = MAXX(FILTER(SparklineTable, [MonthStart] = XMaxDate), [X])
				
				VAR SVGImageURL = 
				    "data:image/svg+xml;utf8," & 
				    "<svg xmlns='http://www.w3.org/2000/svg' x='0px' y='0px' viewBox='-7 -7 164 64'>" & Defs & 
				    "<polyline fill='url(#grad)' fill-opacity='0.3' stroke='transparent' 
				     stroke-width='0' points=' 0 50 " & Lines & 
				     " 150 150 Z '/>" &
				    "<polyline 
				        fill='transparent' stroke='" & LineColour & "' 
				        stroke-linecap='round' stroke-linejoin='round' 
				        stroke-width='2' points=' " & Lines & 
				     " '/>" &
				    "<circle cx='" & LastSparkXValue & "' cy='" & 50 - LastSparkYValue & "' r='4' stroke='" & LineColour & "' stroke-width='2' fill='" & Pointcolour & "' />" &
				    "</svg>"
				
				RETURN SVGImageURL
				```
			displayFolder: Tariffs
			lineageTag: 72816555-2ba1-4bdf-b69a-b4dec40ade55
			dataCategory: ImageUrl

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		/// Adjusted Profit Margin % gap vs target displayed with up/down arrow indicator
		measure 'Adjusted Profit Margin % Target Gap with Arrow' = ```
				
				VAR uparrow = UNICHAR(9650)
				VAR downarrow = UNICHAR(9660)
				VAR square = UNICHAR(9209)
				
				VAR profitmargingap = [Profit Margin % Target Gap]
				
				RETURN
				IF(
				    profitmargingap < 0,
				    FORMAT(profitmargingap, "0.00 %") & " " & downarrow,
				    FORMAT(profitmargingap, "0.00 %") & " " & uparrow
				)
				
				```
			displayFolder: Tariffs
			lineageTag: afcc5ead-6dba-44f0-8c63-d0137e63e9b9
			dataCategory: ImageUrl

			annotation PBI_FormatHint = {"isGeneralNumber":true}

		/// Year-over-year change in Adjusted Profit Margin % compared to prior year
		measure 'Adjusted Profit Margin YoY %' = ```
				
				VAR CurrentMargin = [Adjusted Profit Margin %]
				VAR PriorMargin = CALCULATE([Profit Margin %], DATEADD(DateTable[Date], -1, YEAR))
				RETURN
				IF(
				    NOT ISBLANK(CurrentMargin) && ISBLANK(PriorMargin), 
				    1,
				    CurrentMargin - PriorMargin
				)
				```
			formatString: 0.00%;-0.00%;0.00%
			displayFolder: Tariffs
			lineageTag: 7b711493-e04f-4145-a971-ba4df7547fa1

