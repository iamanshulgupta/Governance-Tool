          },
          {
            "name": "Day Name",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": "FORMAT('weather'[timestamp], \"dddd\")",
            "isDataTypeInferred": true,
            "lineageTag": "4a7fa4b1-ad38-49ab-b1d9-f2fbd505b274",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Heat Index Column",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              },
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "dataType": "double",
            "expression": [
              "",
              "VAR T_C = 'weather'[temperature]",
              "VAR R = 'weather'[humidity]",
              "VAR T = (T_C * 9/5) + 32",
              "VAR HI_F = ",
              "    -42.379 + ",
              "    2.04901523 * T + ",
              "    10.14333127 * R - ",
              "    0.22475541 * T * R - ",
              "    0.00683783 * T * T - ",
              "    0.05481717 * R * R + ",
              "    0.00122874 * T * T * R + ",
              "    0.00085282 * T * R * R - ",
              "    0.00000199 * T * T * R * R",
              "VAR HI_C = (HI_F - 32) * 5/9",
              "RETURN ",
              "IF(T_C < 27, T_C, HI_C)"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "1b3c644f-b8bc-4dbd-9031-743cf4ed0b06",
            "summarizeBy": "sum",
            "type": "calculated"
          }
        ],
        "lineageTag": "f0a746d3-cf86-4a21-ac45-2f28b1e7e394",
        "measures": [
          {
            "name": "Latest Temperature",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "VAR LatestTime =",
              "    MAX (weather[Timestamp] )",
              "RETURN",
              "    CALCULATE (",
              "        MAX (weather[Temperature] ),",
              "        weather[Timestamp] = LatestTime",
              "    )",
              ""
            ],
            "lineageTag": "99a42e17-50f0-4a5b-94af-1492ff908ddb"
          },
          {
            "name": "Latest Humidity",
            "expression": [
              "",
              "VAR LatestTime =",
              "    MAX (weather[Timestamp] )",
              "RETURN",
              "    CALCULATE (",
              "        MAX (weather[Humidity] ),",
              "        weather[Timestamp] = LatestTime",
              "    )"
            ],
            "formatString": "0",
            "lineageTag": "a0fb14f8-97be-439c-88f8-ee5d68c8ae1b"
          },
          {
            "name": "Latest Pressure",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "VAR LatestTime =",
              "    MAX (weather[Timestamp] )",
              "RETURN",
              "    CALCULATE (",
              "        MAX (weather[Pressure] ),",
              "        weather[Timestamp] = LatestTime",
              "    )"
            ],
            "lineageTag": "ac28e371-fad2-44e6-be3d-3f4edce08ec7"
          },
          {
            "name": "IsNight",
            "expression": [
              "",
              "VAR _LatestTimestamp = MAX('weather'[timestamp])",
              "VAR _CurrentHour = HOUR(_LatestTimestamp)",
              "RETURN ",
              "IF(_CurrentHour >= 18 || _CurrentHour < 6, 1, 0)"
            ],
            "formatString": "0",
            "lineageTag": "6cddc72c-344c-4400-a35f-40954359feb9"
          },
          {
            "name": "PressureTrend",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "VAR _LatestTime = MAX('weather'[timestamp])",
              "VAR _CurrentP = [Latest Pressure]",
              "VAR _PastTime = _LatestTime - (3 / 24) -- 3 hours ago",
              "VAR _PastP = ",
              "    CALCULATE(",
              "        AVERAGE('weather'[pressure]), ",
              "        FILTER(",
              "            ALL('weather'), ",
              "            'weather'[timestamp] >= _PastTime - (2/1440) && ",
              "            'weather'[timestamp] <= _PastTime + (2/1440)",
              "        )",
              "    )",
              "RETURN ",
              "IF(ISBLANK(_PastP), 0, _CurrentP - _PastP)"
            ],
            "lineageTag": "08795957-2488-4731-bec8-59fabf3ba95b"
          },
          {
            "name": "Weather Status",
            "expression": [
              "",
              "VAR _P = MAX('weather'[pressure])",
              "VAR _H = MAX('weather'[humidity])",
              "VAR _T = MAX('weather'[temperature])",
              "VAR _Trend = [PressureTrend]",
              "VAR _Night = [IsNight]",
              "",
              "RETURN",
              "SWITCH( TRUE(),",
              "    -- 1. STORMY: Only if pressure is low AND falling very fast",
              "    _P < 1009 && _Trend < -1.5, \"Stormy\",",
              "",
              "    -- 2. RAINY: Pressure is low and dropping",
              "    _P < 1006 && _Trend < 0, \"Rainy\",",
              "",
              "    -- 3. SHOWERS: Pressure is moderate and dropping",
              "    _P < 1010 && _Trend < -0.5, \"Showers\",",
              "",
              "    -- 4. FOGGY: High humidity (Common in early Trichy mornings)",
              "    _H > 92 && _T < 25, \"Foggy\",",
              "",
              "    -- 5. HAZE: Hot and dry (Very common in Trichy)",
              "    _T > 32 && _H < 45, \"Haze\",",
              "",
              "    -- 6. SUNNY / CLEAR: High pressure or stable",
              "    _P >= 1010 && _Trend > -0.5 && _Night = 0, \"Sunny\",",
              "    _P >= 1010 && _Trend > -0.5 && _Night = 1, \"Clear Sky\",",
              "",
              "    -- Default",
              "    \"Partly Sunny\"",
              ")"
            ],
            "lineageTag": "6b8293ac-62d8-45d9-bd43-ffce1e068038"
          },
          {
            "name": "Weather Icon URL",
            "dataCategory": "ImageUrl",
            "expression": [
              "",
              "VAR _Status = [Weather Status]",
              "VAR _Night = [IsNight]",
              "",
              "-- Map the labels to the 'icon' IDs from your CSV",
              "VAR _IconID = ",
              "    SWITCH( TRUE(),",
              "        CONTAINSSTRING(_Status, \"Stormy\"), \"389\", -- Moderate or heavy rain with thunder",
              "        CONTAINSSTRING(_Status, \"Rainy\"), \"308\",  -- Heavy rain",
              "        CONTAINSSTRING(_Status, \"Showers\"), \"353\", -- Light rain shower",
              "        CONTAINSSTRING(_Status, \"Foggy\"), \"248\",   -- Fog",
              "        CONTAINSSTRING(_Status, \"Haze\"), \"143\",    -- Mist (Closest to Haze)",
              "        CONTAINSSTRING(_Status, \"Sunny\"), \"113\",   -- Sunny",
              "        CONTAINSSTRING(_Status, \"Clear Sky\"), \"113\", -- Clear",
              "        \"119\" -- Default Cloudy",
              "    )",
              "",
              "-- Determine the folder (day or night)",
              "VAR _TimeFolder = IF(_Night = 1, \"night\", \"day\")",
              "",
              "RETURN",
              "\"https://cdn.weatherapi.com/weather/64x64/\" & _TimeFolder & \"/\" & _IconID & \".png\""
            ],
            "lineageTag": "20d3738a-7fe3-4d64-a7c1-73f76b9aa730"
          },
          {
            "name": "Feels Like Temp",
            "expression": [
              "",
              "VAR _TC = [Latest Temperature] -- Your temperature measure or MAX('weather'[temperature])",
              "VAR _H = [Latest Humidity]      -- Your humidity measure or MAX('weather'[humidity])",
              "",
              "-- Convert Celsius to Fahrenheit for the formula",
              "VAR _TF = (_TC * 1.8) + 32",
              "",
              "-- Calculate Heat Index in Fahrenheit",
              "VAR _HI_F = ",
              "    IF(_TF < 80, _TF, -- Heat index isn't used below 80°F (26.6°C)",
              "        -42.379 + ",
              "        (2.04901523 * _TF) + ",
              "        (10.14333127 * _H) - ",
              "        (0.22475541 * _TF * _H) - ",
              "        (0.00683783 * (_TF^2)) - ",
              "        (0.05481717 * (_H^2)) + ",
              "        (0.00122874 * (_TF^2) * _H) + ",
              "        (0.00085282 * _TF * (_H^2)) - ",
              "        (0.00000199 * (_TF^2) * (_H^2))",
              "    )",
              "",
              "-- Convert back to Celsius",
              "VAR _HI_C = (_HI_F - 32) / 1.8",
              "",
              "RETURN ",
              "ROUND(_HI_C, 1) & \"°C\""
            ],
            "lineageTag": "197c324e-af48-4317-865e-f24ba221c606"
          },
          {
            "name": "RealTime_DewPoint",
            "expression": [
              "",
              "-- 1. Get the single latest reading from your sensor",
              "VAR _LastUpdate = CALCULATE(MAX('weather'[timestamp]), ALL('weather'))",
              "VAR _T = CALCULATE(MAX('weather'[temperature]), 'weather'[timestamp] = _LastUpdate)",
              "VAR _H = CALCULATE(MAX('weather'[humidity]), 'weather'[timestamp] = _LastUpdate)",
              "",
              "-- 2. Clean the humidity (ensure it's between 0-100)",
              "VAR _CleanH = IF(_H > 100, 100, IF(_H < 0, 0, _H))",
              "",
              "-- 3. Use the most robust meteorological formula (Simple Linear)",
              "-- With T=26.7 and H=67, this MUST result in 20.1",
              "VAR _CalculatedDP = _T - ((100 - _CleanH) / 5)",
              "",
              "RETURN ",
              "IF(ISBLANK(_T), \"Loading...\", ROUND(_CalculatedDP, 1) & \"°C\")"
            ],
            "lineageTag": "725b4cf3-9abe-4caa-90f1-abc0e5c631b0"
          },
          {
            "name": "Comfort Level",
            "expression": [
              "",
              "VAR LastUpdate = CALCULATE(MAX('weather'[timestamp]), ALL('weather'))",
              "VAR T = CALCULATE(MAX('weather'[temperature]), 'weather'[timestamp] = LastUpdate)",
              "VAR H = CALCULATE(MAX('weather'[humidity]), 'weather'[timestamp] = LastUpdate)",
              "",
              "-- 1. Calculate the numeric Dew Point right here",
              "VAR CleanH = IF(H > 100, 100, IF(H < 0, 0, H))",
              "VAR DP = T - ((100 - CleanH) / 5)",
              "",
              "-- 2. Determine the Label",
              "RETURN",
              "SWITCH( TRUE(),",
              "    ISBLANK(T), \"Waiting for Data\",",
              "    DP < 10, \"Very Dry\",",
              "    DP < 13, \"Comfortable\",",
              "    DP < 16, \"Pleasant\",",
              "    DP < 19, \"Slightly Humid\",",
              "    DP < 22, \"Humid and Muggy\",",
              "    DP < 24, \"Very Sticky\",",
              "    \"Oppressive and Extreme\"",
              ")"
            ],
            "lineageTag": "b381abf1-8167-45d8-8260-708c7ec0a852"
          },
          {
            "name": "Daily Max Temp",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "VAR _Today = TODAY()",
              "RETURN",
              "CALCULATE(",
              "    MAX('weather'[temperature]), ",
              "    KEEPFILTERS(DATEVALUE('weather'[timestamp]) = _Today)",
              ")"
            ],
            "lineageTag": "93f0d3fe-595c-472f-a8a3-f2dffbf5e8a0"
          },
          {
            "name": "Daily Min Temp",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "VAR _Today = TODAY()",
              "RETURN",
              "CALCULATE(",
              "    MIN('weather'[temperature]), ",
              "    KEEPFILTERS(DATEVALUE('weather'[timestamp]) = _Today)",
              ")"
            ],
            "lineageTag": "b0efe41a-3b67-4552-ba83-61b99cc2555b"
          },
          {
            "name": "Temp Variation",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "[Daily Max Temp] - [Daily Min Temp]",
            "lineageTag": "f3640264-7f54-4748-a058-929f7348d4ef"
          },
          {
            "name": "Average Heat Index",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "AVERAGEX(",
              "    'weather',",
              "    -- Logic for Heat Index (Celsius)",
              "    VAR T_C = 'weather'[temperature]",
              "    VAR R = 'weather'[humidity]",
              "    VAR T = (T_C * 9/5) + 32",
              "    VAR HI_F = ",
              "        -42.379 + ",
              "        2.04901523 * T + ",
              "        10.14333127 * R - ",
              "        0.22475541 * T * R - ",
              "        0.00683783 * T * T - ",
              "        0.05481717 * R * R + ",
              "        0.00122874 * T * T * R + ",
              "        0.00085282 * T * R * R - ",
              "        0.00000199 * T * T * R * R",
              "    VAR HI_C = (HI_F - 32) * 5/9",
              "    RETURN ",
              "    IF(T_C < 27, T_C, HI_C)",
              ")"
            ],
            "lineageTag": "0431e6cd-122d-4ab9-940a-54cf4f70afef"
          },
          {
            "name": "location",
            "expression": "\"Trichy\"",
            "lineageTag": "f9b287f4-5c8e-4853-9baf-f05ee6f3d5ac"
          },
          {
            "name": "Last Sync Time",
            "expression": [
              "",
              "VAR _IndianTime = UTCNOW() + (5.5 / 24)",
              "RETURN",
              "FORMAT(_IndianTime, \"dd-MMM-yyyy hh:mm AM/PM\")"
            ],
            "lineageTag": "774ca8d1-4979-46f4-88be-9377e071c828"
          }
        ],
