      {
        "name": "ForecastHours",
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "6c685557b6ce470b854cc27249b36aff"
          }
        ],
        "columns": [
          {
            "name": "Value",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "formatString": "0",
            "isDataTypeInferred": true,
            "isNameInferred": true,
            "lineageTag": "b4f9a267-10a1-4612-a9ab-35f503d5b5fc",
            "sourceColumn": "[Value]",
            "summarizeBy": "sum",
            "type": "calculatedTableColumn"
          },
          {
            "name": "Column",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              },
              {
                "name": "43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c",
                "value": "True"
              }
            ],
            "dataType": "int64",
            "isDataTypeInferred": true,
            "lineageTag": "6c1fc545-f625-4ad6-86e5-347109c24729",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "Forecast Time",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "-- Gets current time in IST (UTC+5.5) and adds the hour offset",
              "VAR _CurrentTime = UTCNOW() + (5.5 / 24) ",
              "VAR _FutureTime = _CurrentTime + (ForecastHours[Value] / 24)",
              "RETURN ",
              "FORMAT(_FutureTime, \"h AM/PM\")"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "eb615ade-49f6-47fe-88ab-f2fe622f89f6",
            "summarizeBy": "none",
            "type": "calculated"
          }
        ],
        "lineageTag": "3fd9bf07-8dfa-4c14-be34-f72ddeb6a37e",
        "measures": [
          {
            "name": "Predicted Status",
            "expression": [
              "",
              "VAR _CurrentP = MAX('weather'[pressure])",
              "VAR _Trend = [PressureTrend] / 3 ",
              "VAR _Offset = SELECTEDVALUE('ForecastHours'[Value])",
              "VAR _FutureP = _CurrentP + (_Trend * _Offset)",
              "",
              "-- Calculate if the predicted hour will be night (6 PM to 6 AM)",
              "VAR _CurrentHour = HOUR(MAX('weather'[timestamp]))",
              "VAR _FutureHour = MOD(_CurrentHour + _Offset, 24)",
              "VAR _IsNightForecast = IF(_FutureHour >= 18 || _FutureHour < 6, 1, 0)",
              "",
              "RETURN",
              "SWITCH( TRUE(),",
              "    _FutureP < 1009, \"Stormy ⛈️\",",
              "    _FutureP < 1010.5, \"Rainy 🌧️\",",
              "    -- Night check for clear/sunny",
              "    _IsNightForecast = 1 && _FutureP >= 1011, \"Clear Sky 🌙\",",
              "    _IsNightForecast = 0 && _FutureP >= 1011, \"Sunny ☀️\",",
              "    \"Partly Cloudy ⛅\"",
              ")"
            ],
            "lineageTag": "a1f8e029-38e2-478a-a326-0c161d850b0b"
          },
          {
            "name": "Predicted Temp",
            "expression": [
              "",
              "VAR _CurrentTemp = [Latest Temperature]",
              "VAR _HourNow = HOUR(MAX('weather'[timestamp]))",
              "VAR _FutureHour = _HourNow + SELECTEDVALUE('ForecastHours'[Value])",
              "-- Simple model: Temp rises 1 degree per hour until 3 PM, then falls",
              "VAR _Adjustment = ",
              "    IF(_FutureHour <= 15, ",
              "        SELECTEDVALUE('ForecastHours'[Value]) * 1.2, ",
              "        (SELECTEDVALUE('ForecastHours'[Value]) * -1.2)",
              "    )",
              "RETURN ",
              "ROUND(_CurrentTemp + _Adjustment, 1) & \"°C\""
            ],
            "lineageTag": "f9835848-843a-4263-9677-2429b12b5105"
          }
        ],
        "partitions": [
          {
            "name": "ForecastHours",
            "mode": "import",
            "source": {
              "expression": "GENERATESERIES(1, 6, 1)",
              "type": "calculated"
            }
          }
        ]
      }
    ]
  }
