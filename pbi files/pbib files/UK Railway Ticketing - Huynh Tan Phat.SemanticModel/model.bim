      {
        "name": "DimTime",
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ],
        "columns": [
          {
            "name": "Time",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              },
              {
                "name": "UnderlyingDateTimeDataType",
                "value": "Time"
              }
            ],
            "dataType": "dateTime",
            "formatString": "Long Time",
            "lineageTag": "7cd65f84-7f06-48ac-bfae-7d249c63500c",
            "sourceColumn": "Time",
            "summarizeBy": "none"
          },
          {
            "name": "SortHour",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "dataType": "int64",
            "formatString": "0",
            "isHidden": true,
            "lineageTag": "7f5e220d-c266-4271-b9cf-e04f1fe75d66",
            "sourceColumn": "SortHour",
            "summarizeBy": "none"
          },
          {
            "name": "AM/PM",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "lineageTag": "baa06ed0-b5cf-4cb4-b428-aa211240c5e2",
            "sourceColumn": "AM/PM",
            "summarizeBy": "none"
          },
          {
            "name": "TimeFrame",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "SortByColumn"
              }
            ],
            "dataType": "string",
            "expression": "FORMAT(DimTime[Hour],\"0\") & \" \" & DimTime[AM/PM]",
            "isDataTypeInferred": true,
            "lineageTag": "cb541218-c44a-4a2e-bf60-0bc357e84820",
            "sortByColumn": "SortHour",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Travel Period",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    DimTime[SortHour] >=6 && DimTime[SortHour] <=8, \"Peak Hour\",",
              "    DimTime[SortHour] >=16 && DimTime[SortHour]<=18, \"Peak Hour\",",
              "    \"Off-Peak Hour\")"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "474091f4-6ea6-403b-8bb3-f7c97b0377eb",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Time Slot (AM/PM)",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "VAR peak_hour = DimTime[SortHour]",
              "RETURN",
              "    IF(",
              "        peak_hour >= 6 && peak_hour <= 8, \"6-8AM\",",
              "        IF(peak_hour >= 16 && peak_hour <= 18, \"4-6PM\", \"Other\")",
              "    )"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "2bfa0def-84f3-4c40-9e37-9bf57c461a1c",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Time Category",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "VAR hours = DimTime[SortHour]",
              "RETURN",
              "IF(",
              "    hours >=5 && hours <=12,\"Morning\",",
              "        IF(hours > 12 && hours < 18,\"Afternoon\",",
              "            IF(hours >=18 && hours <=23 , \"Evening\", \"Night\")))"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "76eae5cb-f37c-4c54-a462-5d786032707f",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Hour",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": [
              "",
              "VAR h = DimTime[SortHour]",
              "RETURN",
              "    IF(",
              "        h = 0,",
              "        12,",
              "        IF(h > 12, h - 12, h)",
              "    )",
              ""
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "3ce0f074-5021-452e-90ac-33e62986e519",
            "summarizeBy": "none",
            "type": "calculated"
          }
        ],
        "lineageTag": "ad767bc7-062c-48d9-95fe-548e5a2425b6",
        "partitions": [
          {
            "name": "DimTime",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = {0..1439},",
                "    #\"Converted to Table\" = Table.FromList(Source, Splitter.SplitByNothing(), null, null, ExtraValues.Error),",
                "    #\"Inserted Division\" = Table.AddColumn(#\"Converted to Table\", \"Division\", each [Column1] / 1440, type number),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Inserted Division\",{{\"Division\", type time}}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Changed Type\",{{\"Division\", \"Time in the Whole Day\"}}),",
                "    #\"Inserted Hour\" = Table.AddColumn(#\"Renamed Columns\", \"Hour\", each Time.Hour([Time in the Whole Day]), Int64.Type),",
                "    #\"Added Custom\" = Table.AddColumn(#\"Inserted Hour\", \"time_of_day\", each if Time.Hour([DateTime]) < 12 then \"AM\" else \"PM\"),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Added Custom\",{\"time_of_day\"}),",
                "    #\"Added Custom1\" = Table.AddColumn(#\"Removed Columns\", \"Custom\", each if [Hour] < 12 then \"AM\" else \"PM\"),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Added Custom1\",{{\"Custom\", \"AM/PM\"}, {\"Time in the Whole Day\", \"Time\"}}),",
                "    #\"Removed Columns1\" = Table.RemoveColumns(#\"Renamed Columns1\",{\"Column1\"}),",
                "    #\"Renamed Columns2\" = Table.RenameColumns(#\"Removed Columns1\",{{\"Hour\", \"SortHour\"}})",
                "in",
                "    #\"Renamed Columns2\""
              ],
              "type": "m"
            }
          }
        ]
      },
