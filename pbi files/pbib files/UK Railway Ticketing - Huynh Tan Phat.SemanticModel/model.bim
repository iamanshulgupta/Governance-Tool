          }
        ],
        "lineageTag": "0174a830-103a-45e3-94da-921ae111dcaf",
        "measures": [
          {
            "name": "1_ticket_sales",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": "COUNT(FactTable[transaction_id])",
            "formatString": "0",
            "lineageTag": "c97dbc1a-27b3-40d6-928f-e07e0d15491f"
          },
          {
            "name": "2_gross_revenue",
            "expression": "sum(FactTable[ticket_price])",
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "fb01643b-b357-44dd-8ff9-d6003e1a9954"
          },
          {
            "name": "2_refund_revenue",
            "expression": [
              "CALCULATE(",
              "    SUM(FactTable[ticket_price]),",
              "    FILTER(FactTable,FactTable[refund_requested] = \"Yes\"))"
            ],
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "faf26ebc-3747-4f7c-a30f-184173e28837"
          },
          {
            "name": "2_net_revenue",
            "expression": [
              "//ticket_sold * price (actual earned)",
              "CALCULATE(",
              "    SUMX(FactTable,FactTable[ticket_price]),",
              "    FactTable[refund_requested] = \"No\")"
            ],
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "6bea22f9-9622-4ed6-9355-af4e78300229"
          },
          {
            "name": "2_average_price_per_ticket (APT)",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ],
            "expression": [
              "",
              "DIVIDE([2_gross_revenue],[1_ticket_sales])"
            ],
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "lineageTag": "05165168-fad9-4730-a92e-453b998cf8a2"
          },
          {
            "name": "1_refunded_ticket_sales",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isDecimal\":true}"
              }
            ],
            "expression": [
              "CALCULATE(",
              "    COUNTROWS(FactTable),",
              "    FILTER(FactTable,FactTable[refund_requested] = \"Yes\"))"
            ],
            "formatString": "0",
            "isHidden": true,
            "lineageTag": "72747276-7786-402b-a3e5-55a268341251"
          },
          {
            "name": "1_cancelled_ticket_sales",
            "expression": [
              "CALCULATE(",
              "    COUNT(FactTable[transaction_id]),",
              "    FILTER(FactTable,FactTable[journey_status] = \"Cancelled\"))"
            ],
            "formatString": "0",
            "lineageTag": "cbeef468-b5b7-456f-9e14-6827f4d69f78"
          },
          {
            "name": "3_total_train_trips",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "-- Đếm từng số chuyến đi theo ngày của từng route",
              "VAR total_train_trips = -- Mục đích: Trong tất cả các chuyến trong dataset, có bao nhiêu chuyến đến đúng giờ | trễ | hủy ",
              "    SUMMARIZECOLUMNS(",
              "        DimDate[Date],",
              "        DimStation[route],",
              "        \"Trips\", DISTINCTCOUNT(FactTable[departure_time]) -- Mỗi chuyến sẽ đếm dựa trên departure time không trùng lặp ",
              "    )",
              "RETURN",
              "SUMX(total_train_trips, [Trips])"
            ],
            "lineageTag": "966e49d3-e621-4e85-b30c-85807f002a9f"
          },
          {
            "name": "3_on-time train trips",
            "expression": [
              "",
              "VAR on_time_train_trips =",
              "    SUMMARIZECOLUMNS(",
              "        DimDate[Date],",
              "        DimStation[route],",
              "        FILTER(FactTable,FactTable[journey_status] = \"On Time\"),",
              "        \"Trips\", DISTINCTCOUNT(FactTable[departure_time]))",
              "RETURN",
              "SUMX(on_time_train_trips, [Trips])"
            ],
            "formatString": "0",
            "lineageTag": "8477587d-ee5d-4eb6-b65e-84b57f7d1a41"
          },
          {
            "name": "3_delayed train trips",
            "expression": [
              "",
              "VAR delayed_train_trips =",
              "    SUMMARIZECOLUMNS(",
              "        DimDate[Date],",
              "        DimStation[route],",
              "        FILTER(FactTable,FactTable[journey_status] = \"Delayed\"),",
              "        \"Trips\", DISTINCTCOUNT(FactTable[departure_time]))",
              "RETURN",
              "SUMX(delayed_train_trips, [Trips])"
            ],
            "formatString": "0",
            "lineageTag": "f06fd7d1-3abc-4225-ba19-5503be5dd897"
          },
          {
            "name": "3_cancelled train trips",
            "expression": [
              "",
              "VAR total_cancelled_train_trips =",
              "    SUMMARIZECOLUMNS(",
              "        DimDate[Date],",
              "        DimStation[route],",
              "        FILTER(FactTable,FactTable[journey_status] = \"Cancelled\"),",
              "        \"Trips\", DISTINCTCOUNT(FactTable[departure_time]))",
              "RETURN",
              "SUMX(total_cancelled_train_trips, [Trips])"
            ],
            "formatString": "0",
            "lineageTag": "3a3b46bd-54a9-4367-a359-cc1107b33698"
          },
          {
            "name": "4_%On-Time Performance",
            "expression": [
              "--(Number of Trips On Time / Total Number of Trips arrived Train Stops) x 100",
              "DIVIDE( --On-Time + Delayed  không thêm Cancelled, bởi vì chuyến tàu bị hủy không đi tới \"train stops\"",
              "    [3_on-time train trips],",
              "    [3_on-time train trips] + [3_delayed train trips])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "09724e0f-2bf4-4749-85f2-949b5b9a6e15"
          },
          {
            "name": "5_%Delayed Reliablity",
            "expression": [
              "",
              "DIVIDE( ",
              "    [3_delayed train trips],",
              "    [3_total_train_trips])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "5cc83b19-2b3f-42c0-bc53-931cbaaabdad"
          },
          {
            "name": "5_%OTP Reliablity",
            "expression": [
              "",
              "DIVIDE( ",
              "    [3_on-time train trips],",
              "    [3_total_train_trips])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "241fef94-d4db-457f-ae19-2a86dd4b60a5"
          },
          {
            "name": "5_%Cancelled Reliablity",
            "expression": [
              "",
              "DIVIDE( ",
              "    [3_cancelled train trips],",
              "    [3_total_train_trips])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "7833797a-e197-41e9-a2ab-7c4a998e76c2"
          },
          {
            "name": "1_net_ticket_sales",
            "expression": [
              "CALCULATE(",
              "    COUNTROWS(FactTable),",
              "    FILTER(FactTable,FactTable[refund_requested] = \"No\"))"
            ],
            "formatString": "0",
            "lineageTag": "9edf3401-1882-4da5-ac94-3d88d293adc9"
          },
          {
            "name": "1_delayed_ticket_sales",
            "expression": [
              "CALCULATE(",
              "    COUNT(FactTable[transaction_id]),",
              "    FILTER(FactTable,FactTable[journey_status] = \"Delayed\"))"
            ],
            "formatString": "0",
            "lineageTag": "877b65b2-b5ab-406e-809d-abdbb24e3b74"
          }
        ],
        "partitions": [
          {
            "name": "MetricTable",
            "mode": "import",
            "source": {
              "expression": "Row(\"Column\", BLANK())",
              "type": "calculated"
            }
          }
        ]
