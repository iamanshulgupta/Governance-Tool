          {
            "name": "FactTable",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(\"C:\\Users\\admin\\Documents\\DATA ANALYST\\Project\\2025\\Ticketing Dataset\\railway_ticket.csv\"),[Delimiter=\",\", Columns=19, Encoding=1252, QuoteStyle=QuoteStyle.None]),",
                "    #\"Promoted Headers\" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Promoted Headers\",{{\"transaction_id\", Int64.Type}, {\"purchase_date\", type date}, {\"purchase_time\", type time}, {\"purchase_type\", type text}, {\"payment_method\", type text}, {\"railcard\", type text}, {\"ticket_class\", type text}, {\"ticket_type\", type text}, {\"ticket_price\", type number}, {\"departure_station\", type text}, {\"arrival_station\", type text}, {\"journey_date\", type date}, {\"departure_time\", type time}, {\"arrival_time\", type time}, {\"actual_arrival_time\", type time}, {\"journey_status\", type text}, {\"delay_reason\", type text}, {\"refund_requested\", type text}, {\"arrival_date\", type date}}),",
                "    #\"Reordered Columns\" = Table.ReorderColumns(#\"Changed Type\",{\"transaction_id\", \"purchase_date\", \"purchase_time\", \"purchase_type\", \"payment_method\", \"railcard\", \"ticket_class\", \"ticket_type\", \"ticket_price\", \"departure_station\", \"arrival_station\", \"journey_date\", \"departure_time\", \"arrival_date\", \"arrival_time\", \"actual_arrival_time\", \"journey_status\", \"delay_reason\", \"refund_requested\"}),",
                "    #\"Filtered Rows\" = Table.SelectRows(#\"Reordered Columns\", each true),",
                "    #\"Merged \"\"DimPurchase\"\"\" = Table.NestedJoin(#\"Filtered Rows\", {\"purchase_type\", \"payment_method\"}, DimPurchase, {\"purchase_type\", \"payment_method\"}, \"DimPurchase\", JoinKind.LeftOuter),",
                "    #\"Expanded DimPurchase\" = Table.ExpandTableColumn(#\"Merged \"\"DimPurchase\"\"\", \"DimPurchase\", {\"purchase_key\"}, {\"DimPurchase.purchase_key\"}),",
                "    #\"Renamed DimPurchase\" = Table.RenameColumns(#\"Expanded DimPurchase\",{{\"DimPurchase.purchase_key\", \"purchase_key\"}}),",
                "    #\"Removed \"\"DimPurchase\"\" Columns\" = Table.RemoveColumns(#\"Renamed DimPurchase\",{\"purchase_type\", \"payment_method\"}),",
                "    #\"Merged \"\"DimTicketInfo\"\"\" = Table.NestedJoin(#\"Removed \"\"DimPurchase\"\" Columns\", {\"ticket_class\", \"ticket_type\"}, DimTicketInfo, {\"ticket_class\", \"ticket_type\"}, \"DimTicketInfo\", JoinKind.LeftOuter),",
                "    #\"Expanded DimTicketInfo\" = Table.ExpandTableColumn(#\"Merged \"\"DimTicketInfo\"\"\", \"DimTicketInfo\", {\"ticket_key\"}, {\"DimTicketInfo.ticket_key\"}),",
                "    #\"Renamed Columns\" = Table.RenameColumns(#\"Expanded DimTicketInfo\",{{\"DimTicketInfo.ticket_key\", \"ticket_key\"}}),",
                "    #\"Removed \"\"DimTicketInfo\"\" Columns\" = Table.RemoveColumns(#\"Renamed Columns\",{\"ticket_class\", \"ticket_type\"}),",
                "    #\"Merged \"\"DimStation\"\"\" = Table.NestedJoin(#\"Removed \"\"DimTicketInfo\"\" Columns\", {\"departure_station\", \"arrival_station\"}, DimStation, {\"departure_station\", \"arrival_station\"}, \"DimStation\", JoinKind.LeftOuter),",
                "    #\"Expanded DimStation\" = Table.ExpandTableColumn(#\"Merged \"\"DimStation\"\"\", \"DimStation\", {\"station_key\"}, {\"DimStation.station_key\"}),",
                "    #\"Renamed Columns1\" = Table.RenameColumns(#\"Expanded DimStation\",{{\"DimStation.station_key\", \"station_key\"}}),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Renamed Columns1\",{\"departure_station\", \"arrival_station\"}),",
                "    #\"Merged Queries\" = Table.NestedJoin(#\"Removed Columns\", {\"railcard\"}, DimCustomerCard, {\"railcard\"}, \"DimCustomerCard\", JoinKind.LeftOuter),",
                "    #\"Expanded DimCustomerCard\" = Table.ExpandTableColumn(#\"Merged Queries\", \"DimCustomerCard\", {\"railcard_key\"}, {\"DimCustomerCard.railcard_key\"}),",
                "    #\"Renamed Columns2\" = Table.RenameColumns(#\"Expanded DimCustomerCard\",{{\"DimCustomerCard.railcard_key\", \"railcard_key\"}}),",
                "    #\"Removed Columns1\" = Table.RemoveColumns(#\"Renamed Columns2\",{\"railcard\"}),",
                "    #\"Duplicated Column\" = Table.DuplicateColumn(#\"Removed Columns1\", \"purchase_time\", \"purchase_time - Copy\"),",
                "    #\"Renamed Columns3\" = Table.RenameColumns(#\"Duplicated Column\",{{\"purchase_time - Copy\", \"purchase_hour\"}}),",
                "    #\"Removed Columns2\" = Table.RemoveColumns(#\"Renamed Columns3\",{\"purchase_hour\"}),",
                "    #\"Renamed Columns4\" = Table.RenameColumns(#\"Removed Columns2\",{{\"journey_date\", \"departure_date\"}, {\"journey_status\", \"journey_status\"}}),",
                "    #\"Added Custom\" = Table.AddColumn(#\"Renamed Columns4\", \"Custom\", each Duration.Minutes([actual_arrival_time]-[arrival_time])),",
                "    #\"Renamed Columns5\" = Table.RenameColumns(#\"Added Custom\",{{\"Custom\", \"trains_punc\"}}),",
                "    #\"Added Custom1\" = Table.AddColumn(",
                "    #\"Renamed Columns5\",",
                "    \"train_status\",",
                "    each",
                "        if [journey_status] = \"Cancelled\" then \"Trains Cancelled\"",
                "        else",
                "            let",
                "                minutes =",
                "                    Duration.TotalMinutes(",
                "                        [actual_arrival_time] - [arrival_time]",
                "                    )",
                "            in",
                "                if minutes < 0 then \"Early\"",
                "                else if minutes = 0 then \"On-Time\"",
                "                else if minutes <= 3 then \"Within 3 mins\"",
                "                else if minutes <= 5 then \"Within 5 mins\"",
                "                else if minutes <= 10 then \"Within 10 mins\"",
                "                else if minutes <= 15 then \"10 mins+\"",
                "                else if minutes <= 20 then \"15 mins+\"",
                "                else if minutes <= 30 then \"20 mins+\"",
                "                else \"30 mins+\"",
                "),",
                "    #\"Renamed Columns6\" = Table.RenameColumns(#\"Added Custom1\",{{\"trains_punc\", \"train_punctuality_minutes\"}, {\"train_status\", \"train_status_arriving_train_stops\"}}),",
                "    #\"Removed Columns3\" = Table.RemoveColumns(#\"Renamed Columns6\",{\"train_punctuality_minutes\"})",
                "in",
                "    #\"Removed Columns3\""
              ],
              "type": "m"
            }
          }
        ]
      },
