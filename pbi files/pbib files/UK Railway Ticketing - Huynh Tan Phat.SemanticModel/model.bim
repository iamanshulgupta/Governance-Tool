              "",
              "VAR SelectedMetric = SELECTEDVALUE('MetricParameter (Overview)'[Metrics])",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"Net Ticket Sales\", CALCULATE(AVERAGEX(VALUES(DimStation[arrival_station]),[1_ticket_sales]),FILTER(FactTable,FactTable[refund_requested] = \"No\")),",
              "    \"Net Revenue\", CALCULATE(AVERAGEX(VALUES(DimStation[arrival_station]),[2_gross_revenue]),FILTER(FactTable,FactTable[refund_requested] = \"No\")),",
              "    BLANK())"
            ],
            "lineageTag": "8796a0c5-1def-40b6-bc99-dc3ae82d3acf"
          }
        ],
        "partitions": [
