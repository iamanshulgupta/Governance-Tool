        "partitions": [
          {
            "name": "SortTrainStatus",
            "mode": "import",
            "source": {
              "expression": [
                "",
                "DATATABLE(",
                "    \"TrainStatus\", STRING,",
                "    \"Sort\", INTEGER,",
                "    {",
                "        {\"Early\", 0},",
                "        {\"On-Time\",1},",
