          }
        ],
        "lineageTag": "71d57b92-6d18-478d-a9e8-eb9daba80fb8",
        "measures": [
          {
            "name": "SelectedMetricValue",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    SELECTEDVALUE('MetricParameter (Overview)'[Metrics]) = \"Net Ticket Sales\",CALCULATE([1_ticket_sales],FILTER(FactTable,FactTable[refund_requested] = \"No\")),",
              "    SELECTEDVALUE('MetricParameter (Overview)'[Metrics]) = \"Net Revenue\", CALCULATE([2_gross_revenue],FILTER(FactTable,FactTable[refund_requested] = \"No\")))"
            ],
            "lineageTag": "865ba362-d59e-4f3b-b593-ccc01c96d843"
          },
          {
            "name": "SelectedAvgRoute",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE('MetricParameter (Overview)'[Metrics])",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"Net Ticket Sales\", CALCULATE(AVERAGEX(VALUES(DimStation[City]),[1_ticket_sales]),FILTER(FactTable,FactTable[refund_requested] = \"No\")),",
              "    \"Net Revenue\", CALCULATE(AVERAGEX(VALUES(DimStation[City]),[2_gross_revenue]),FILTER(FactTable,FactTable[refund_requested] = \"No\")),",
              "    BLANK())"
            ],
            "lineageTag": "4bfdb9e3-8861-4bc7-befe-326a07c8322e"
          },
          {
            "name": "SelectedAvgDeparture",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE('MetricParameter (Overview)'[Metrics])",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"Net Ticket Sales\", CALCULATE(AVERAGEX(VALUES(DimStation[departure_station]),[1_ticket_sales]),FILTER(FactTable,FactTable[refund_requested] = \"No\")),",
              "    \"Net Revenue\", CALCULATE(AVERAGEX(VALUES(DimStation[departure_station]),[2_gross_revenue]),FILTER(FactTable,FactTable[refund_requested] = \"No\")),",
              "    BLANK())"
            ],
            "lineageTag": "3c7b3bba-dc5a-460e-aa3b-f53456b7ed07"
          },
          {
            "name": "SelectedAvgArrival",
