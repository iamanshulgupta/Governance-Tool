        "partitions": [
          {
            "name": "RankingRouteTable for Page 5",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Sql.Database(\"CALL-ME-KAEL\", \"Kaggle - UK Railway Ticket\", [Query=\"With ranking_routes_based_on_criterias as (#(lf)SELECT#(tab)city, route,#(lf)#(tab)#(tab)total_train_trips, total_passengers,#(lf)#(tab)#(tab)net_revenue, average_price_per_ticket,#(lf)#(tab)#(tab)delayed_passengers, cancelled_passengers, refund_revenue,#(lf)#(tab)#(tab)on_time_trips, round(cast(replace(on_time_pct,'%','') as float) / 100,3) as otp,#(lf)#(tab)#(tab)delayed_trips, cancelled_trips#(lf)FROM detailed_value_table#(lf)), high_revenue_poor_otp as ( --Top 3 Nhóm tuyến doanh thu cao nhưng hiệu suất vận hành OTP kém#(lf)SELECT#(tab)*,#(lf)#(tab)#(tab)ROW_NUMBER() OVER (ORDER BY net_revenue DESC, otp asc) as ranking_high_revenue_poor_otp#(lf)FROM ranking_routes_based_on_criterias#(lf)where otp < 0.8#(lf)), high_otp_poor_delay_cancelled as ( --Top 3 Nhóm tuyến có On-Time cao, nhưng Delay và  Cancelled cao#(lf)SELECT#(tab)*,#(lf)#(tab)#(tab)ROW_NUMBER() OVER (ORDER BY cancelled_trips desc, cancelled_passengers desc, delayed_trips desc, delayed_passengers desc) as ranking_high_otp_poor_delay_cancelled#(lf)FROM ranking_routes_based_on_criterias#(lf)WHERE otp between 0.9 and 0.99  --Phải lọc filter <>1, bởi vì nếu giảm được %delay thì sẽ cải thiện on-time = 100%#(lf)), poor_revenue_passengers as ( -- Nhóm tuyến có doanh thu và lượng khách cực kì thấp , không nằm trong top 3 thành phố có lượng vé bán cao #(lf)SELECT#(tab)*,#(lf)#(tab)#(tab)ROW_NUMBER() OVER (ORDER BY net_revenue asc, total_passengers asc) as ranking_revenue_contribution#(lf)FROM detailed_value_table#(lf)WHERE city not in ('London', 'Manchester', 'Liverpool')#(lf))#(lf)SELECT#(tab)r1.*,#(lf)#(tab)#(tab)--r1.city, r1.route,#(lf)#(tab)#(tab)h1.ranking_high_revenue_poor_otp, h2.ranking_high_otp_poor_delay_cancelled, p1.ranking_revenue_contribution#(lf)FROM ranking_routes_based_on_criterias r1#(lf)LEFT JOIN high_revenue_poor_otp h1#(lf)#(tab)ON r1.route = h1.route#(lf)LEFT JOIN high_otp_poor_delay_cancelled h2#(lf)#(tab)ON r1.route = h2.route#(lf)LEFT JOIN poor_revenue_passengers p1#(lf)#(tab)ON r1.route = p1.route#(lf)--where h1.ranking_high_revenue_poor_otp <=3 or h2.ranking_high_otp_poor_delay_cancelled <=3 or p1.ranking_revenue_contribution <=3#(lf)ORDER BY h1.ranking_high_revenue_poor_otp asc, h2.ranking_high_otp_poor_delay_cancelled asc, p1.ranking_revenue_contribution asc;\"]),",
                "    #\"Renamed Columns\" = Table.RenameColumns(Source,{{\"otp\", \"on-time-performance(otp)\"}}),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Renamed Columns\",{{\"on-time-performance(otp)\", Percentage.Type}})",
                "in",
                "    #\"Changed Type\""
              ],
              "type": "m"
            }
          }
        ]
      },
