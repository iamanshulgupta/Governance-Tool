        "lineageTag": "501d3c4d-da83-4861-a562-b9f2d94c4cfb",
        "measures": [
          {
            "name": "1_Selected Dynamic Title by Departure Station",
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE('MetricParameter (Overview)'[Metrics])",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"Net Ticket Sales\", \"Ticket Sales by Departure Station\",",
              "    \"Net Revenue\", \"Revenue by Departure Station\",",
              "    BLANK())"
            ],
            "lineageTag": "87da4218-6646-43c4-9419-a2b0983214ce"
          },
          {
            "name": "1_Selected Dynamic Title by Arrival Station",
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE('MetricParameter (Overview)'[Metrics])",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"Net Ticket Sales\", \"Ticket Sales by Arrival Station\",",
              "    \"Net Revenue\", \"Revenue by Arrival Station\",",
              "    BLANK())"
            ],
            "lineageTag": "d13c82c7-2f26-4f41-9c64-6878d138a809"
          },
          {
            "name": "1_Selected Dynamic Title by City",
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE('MetricParameter (Overview)'[Metrics])",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"Net Ticket Sales\", \"Ticket Sales by City\",",
              "    \"Net Revenue\", \"Revenue by City\",",
              "    BLANK())"
            ],
            "lineageTag": "2cf06f76-2998-4826-90dc-4e8e020369bd"
          },
          {
            "name": "1_Selected Dynamic Title by Year Month",
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE('MetricParameter (Overview)'[Metrics])",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"Net Ticket Sales\", \"Ticket Sales stabilize over time\",",
              "    \"Net Revenue\", \"Revenue stabilize over time\",",
              "    BLANK())"
            ],
            "lineageTag": "3a809830-e6a4-4973-ab3b-4d4d966dbabd"
          },
          {
            "name": "1_Selected Dynamic Drill Down Chart Title",
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE('MetricParameter (Overview)'[Metrics])",
              "",
              "VAR PurchaseType = SELECTEDVALUE(DimPurchase[purchase_type],\"Purchase Type\")",
              "VAR TicketClass = IF(",
              "    ISFILTERED(DimTicketInfo[ticket_class]),",
              "    SELECTEDVALUE(DimTicketInfo[ticket_class]) & \" \",",
              "    \"\")",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"Net Ticket Sales\",\"Ticket Sales & Avg. Price for \" & TicketClass & PurchaseType,",
              "    \"Net Revenue\", \"Revenue & Avg. Price for \" & TicketClass &PurchaseType)"
            ],
            "lineageTag": "cb13c6d2-ae32-4741-9f4b-b5a264085542"
          },
          {
            "name": "2_Selected Dynamic Title by A.M / P.M",
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE(DimTime[AM/PM])",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"AM\", \"Peak Hours for Passenger Journey in the AM period\",",
              "    \"PM\", \"Peak Hours for Passenger Journey in the PM period\",",
              "    BLANK())"
            ],
            "lineageTag": "56827e1c-8202-4930-81ff-9d0c5d376631"
          },
          {
            "name": "2_Selected Dynamic Title by TimeSlot",
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE(DimTime[AM/PM])",
              "RETURN",
              "SWITCH(",
              "    SelectedMetric,",
              "    \"AM\", \"Time Slots within Peak Hours in the AM period\",",
              "    \"PM\", \"Time Slots within Peak Hours in the PM period\",",
              "    BLANK())"
            ],
            "lineageTag": "3d4db933-70bb-446b-917c-eca5b3a15237"
          },
          {
            "name": "3_OTP Value & PCT",
            "expression": [
              "",
              "FORMAT([3_on-time train trips],\"#,##\") & \" | \" & FORMAT([4_%On-Time Performance],\"00.00%\")"
            ],
            "lineageTag": "417531cc-aa76-4e38-bd5d-707eedf92d88"
          },
          {
            "name": "4_Selected Dynamic Delay/Cancelled",
            "expression": [
              "",
              "VAR SelectedMetric = SELECTEDVALUE(FactTable[journey_status])",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    SelectedMetric = \"Delayed\", \"Contributing Factors affecting OTP by Delay Reasons\",",
              "    SelectedMetric = \"Cancelled\", \"Contributing Factors affecting OTP by Cancelled Reasons\",",
              "    BLANK())"
            ],
            "lineageTag": "a44ce353-90be-43fa-8c8b-2ca0eb4487f5"
          },
          {
            "name": "5_%Operational Reliability",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "DIVIDE(",
              "    [3_total_train_trips],",
              "    CALCULATE(",
              "        [3_total_train_trips],",
              "        REMOVEFILTERS(FactTable[train_status_arriving_train_stops])))"
            ],
            "lineageTag": "13e81404-6fc1-42b6-a129-08897ef818a0"
          }
        ],
