                "name": "SummarizationSetBy",
                "value": "User"
              }
            ],
            "dataType": "int64",
            "expression": "YEAR('people_fact'[hire_date])",
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "2cc566ef-c617-4d9b-b5b0-fabeb256648b",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Termination Year",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": [
              "",
              "IF (",
              "    ISBLANK('people_fact'[term_date]), ",
              "    BLANK(), ",
              "    YEAR('people_fact'[term_date])",
              ")"
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "513fa927-96c2-4c5b-967c-9b6a342b0660",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "Tenure at Exit",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": [
              "",
              "IF(",
              "    NOT(ISBLANK('people_fact'[term_date])),",
              "    DATEDIFF('people_fact'[hire_date], 'people_fact'[term_date], YEAR),",
              "    BLANK()",
              ")"
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "295de3a7-b5a0-480d-9f49-3fce0941f158",
            "summarizeBy": "sum",
            "type": "calculated"
          }
        ],
