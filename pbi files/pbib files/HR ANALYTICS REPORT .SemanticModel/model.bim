        "lineageTag": "c116b5d3-75d0-4b2c-a54c-3a586d9a4f37",
        "partitions": [
          {
            "name": "Date Table1",
            "mode": "import",
            "source": {
              "expression": [
                "",
                "VAR MinDate = MIN('people_fact'[hire_date])",
                "VAR MaxDate = MAX('people_fact'[term_date])",
                "// Optional: If you want the calendar to cover the full year of the MaxDate",
                "VAR EndOfCalendar = DATE(YEAR(MaxDate), 12, 31) ",
                "",
                "RETURN",
                "ADDCOLUMNS (",
                "    CALENDAR ( MinDate, EndOfCalendar ),",
                "    \"Year\", YEAR ( [Date] ),",
                "    \"Month Number\", MONTH ( [Date] ),",
                "    \"Month Name\", FORMAT ( [Date], \"MMMM\" ),",
                "    \"Quarter\", \"Q\" & FORMAT ( [Date], \"Q\" ),",
                "    \"Year Month\", FORMAT ( [Date], \"YYYY-MM\" ),",
                "    \"Day of Week\", WEEKDAY ( [Date] ),",
                "    \"Day Name\", FORMAT ( [Date], \"DDDD\" )",
                ")"
              ],
              "type": "calculated"
            }
          }
        ]
      },
