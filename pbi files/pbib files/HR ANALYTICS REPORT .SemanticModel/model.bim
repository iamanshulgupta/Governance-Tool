      {
        "name": "_Measures",
        "annotations": [
          {
            "name": "PBI_NavigationStepName",
            "value": "Navigation"
          },
          {
            "name": "PBI_ResultType",
            "value": "Table"
          }
        ],
        "columns": [
          {
            "name": "Column1",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "dataType": "string",
            "isHidden": true,
            "lineageTag": "16aac2dd-a5f1-49b9-b0f9-93007fd84af7",
            "sourceColumn": "Column1",
            "summarizeBy": "none"
          }
        ],
        "lineageTag": "7f4f57bc-714d-45bc-ac58-ac24728f155d",
        "measures": [
          {
            "name": "All Employees",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "DISTINCTCOUNT(people_fact[employee_id])",
            "formatString": "#,0",
            "lineageTag": "158bcadd-1ffe-4b9d-9197-0ce8c54fc2b9"
          },
          {
            "name": "Headcount",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "CALCULATE([All Employees],FILTER(people_fact,people_fact[hire_date]<=LASTDATE('Date'[Date]) && (people_fact[term_date]>LASTDATE('Date'[Date]) || people_fact[term_date]=BLANK())))",
            "formatString": "#,0",
            "lineageTag": "7af83482-292a-4062-88a8-30f1c090ae1b"
          },
          {
            "name": "Starting Headcount",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "CALCULATE([All Employees], filter(people_fact, people_fact[hire_date]<FIRSTDATE('Date'[Date]) && (people_fact[term_date]=BLANK() || people_fact[term_date]>=FIRSTDATE('Date'[Date]))))",
            "formatString": "#,0",
            "lineageTag": "a1f05d66-44c5-49d5-a8fa-d501715251af"
          },
          {
            "name": "Ending Headcount",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "CALCULATE([All Employees],filter(people_fact,people_fact[hire_date]<FIRSTDATE('Date'[Date]) && (people_fact[term_date]=BLANK() || people_fact[term_date]>=LASTDATE('Date'[Date]))))",
            "formatString": "#,0",
            "lineageTag": "56d2b976-56c0-4c72-b833-d90ab61ce343"
          },
          {
            "name": "Retention",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "DIVIDE([Ending Headcount],[Starting Headcount])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "e45262f0-d6e5-419b-b2c3-19cc120dd4bd"
          },
          {
            "name": "Avg # of Employees",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "([Starting Headcount] + [Headcount])/2",
            "lineageTag": "935c1f55-2a25-483c-a33a-3c2d471f0b06"
          },
          {
            "name": "Departing Employees",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "Calculate([All Employees],filter(people_fact,people_fact[term_date]>=FIRSTDATE('Date'[Date]) && people_fact[term_date]<=LASTDATE('Date'[Date])))",
            "formatString": "0",
            "lineageTag": "2062834c-93b2-4cb0-bf76-2bd6ceea7042"
          },
          {
            "name": "Turnover %",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "DIVIDE([Departing Employees],[Avg # of Employees])",
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "6d3549bf-5062-449e-bc53-f9d1b44e1e84"
          },
          {
            "name": "Min-Max Retention",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": [
              "",
              "    SWITCH(TRUE(),",
              "        SELECTEDVALUE('Date'[Year])=CALCULATE(min('Date'[Year]),ALLSELECTED('Date')),[Retention],",
              "        SELECTEDVALUE('Date'[Year])=CALCULATE(max('Date'[Year]),ALLSELECTED('Date')),[Retention],",
              "        BLANK()",
              "        )"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "39168939-f5be-407a-969c-3a7d3562f248"
          },
          {
            "name": "Current Headcount Title",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "\"What is Our Headcount as of \" & max('Date'[Year]) & \"?\"",
            "lineageTag": "c663ae67-9494-406d-a146-3240cc8000a1"
          },
          {
            "name": "Current Retention Title",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "\"What is Retention for \" & Min('Date'[Year]) & \" - \" & max('Date'[Year]) & \"?\"",
            "lineageTag": "055ff15f-d9e5-4b81-8c9d-bc63530e2ee5"
          },
          {
            "name": "Starting Headcount Text",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "\"Starting Headcount: \" & format([Starting Headcount],\"###,##0\")",
            "lineageTag": "0c0c1674-1df3-42e2-ac31-0f1362fb9ebe"
          },
          {
            "name": "Ending Headcount Text",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "\"Ending Headcount: \" & format([Ending Headcount],\"###,##0\")",
            "lineageTag": "c01614de-a25a-4252-98db-d14279d3576e"
          },
          {
            "name": "Parameter Title",
            "changedProperties": [
              {
                "property": "IsHidden"
              }
            ],
            "expression": "\"Select a Field for Which to Compare Employee Retention for the Timeframe \" & min('Date'[Year]) & \"-\" & max('Date'[Year])",
            "lineageTag": "5a5a1325-78cb-4726-bfb0-6f7b0417eccb"
          },
          {
            "name": "Slope Chart Title",
            "expression": "\"How Has Employee Retention Changed Between \" & Min('Date'[Year]) & \" & \" & max('Date'[Year]) & \" by \" & min(Parameter[Parameter]) & \"?\"",
            "lineageTag": "bd85272c-a307-4d92-92ca-94166df7dcef"
          },
          {
            "name": "Departing Employees Text",
            "expression": "\"Departing Employees: \" & FORMAT([Departing Employees],\"###,##0\")",
            "lineageTag": "829ce731-2fa1-4d99-ae2a-09917533e7c7"
          },
          {
            "name": "Continuous Retention Range",
            "expression": [
              "",
              "VAR MinYear = CALCULATE(MIN('Date'[Year]), ALLSELECTED('Date'))",
              "VAR MaxYear = CALCULATE(MAX('Date'[Year]), ALLSELECTED('Date'))",
              "VAR CurrentYear = SELECTEDVALUE('Date'[Year])",
              "",
              "RETURN",
              "CALCULATE(",
              "    [Retention],",
              "    KEEPFILTERS('Date'[Year] >= MinYear && 'Date'[Year] <= MaxYear),",
              "    ALL('Date'[Year]) -- This line tells the measure to ignore the specific years you clicked",
              ")"
            ],
            "formatString": "0.0%;-0.0%;0.0%",
            "lineageTag": "b48807f2-9e34-4ea4-a491-f0de48e4dc99"
          },
          {
            "name": "Avg. # of Employees Text",
            "expression": "\"AVG No. of Employees: \" & FORMAT([Avg # of Employees],\"###,##0.0\")",
            "lineageTag": "7f13fc2d-42cc-4970-a859-dceac1a5e5af"
          },
          {
            "name": "% Single",
            "expression": [
              "",
              "VAR SingleHeadcount = CALCULATE(",
              "    [Headcount], ",
              "    'marital_dim'[marital_status] = \"Single\"",
              ")",
              "RETURN",
              "    DIVIDE(SingleHeadcount, [Headcount], 0)"
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "3ce65101-dc4a-475a-92e1-6bc513282053"
          },
          {
            "name": "% Male",
            "expression": [
              "",
              "VAR MaleHeadcount = CALCULATE(",
              "    [Headcount], ",
              "    'demographic_dim'[Gender] = \"Male\"  // Change \"Male\" to \"M\" if that is how it is stored in your data",
              ")",
              "RETURN",
              "    DIVIDE(MaleHeadcount, [Headcount], 0)"
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "bce9eea1-ed14-486b-a161-90bd9cae4b3f"
          },
          {
            "name": "Headcount LY",
            "expression": [
              "",
              "CALCULATE(",
              "    [Headcount], ",
              "    SAMEPERIODLASTYEAR('Date'[Date])",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "01058520-2d1c-40cf-b656-20b7a68d6dca"
          },
          {
            "name": "Headcount YoY %",
            "expression": [
              "",
              "VAR CurrentHeadcount = [Headcount]",
              "VAR PreviousHeadcount = [Headcount LY]",
              "RETURN",
              "    DIVIDE(CurrentHeadcount - PreviousHeadcount, PreviousHeadcount, 0)"
            ],
            "formatString": "0",
            "lineageTag": "972a3ead-b2c2-4d0c-b3e4-1da67c8f937c"
          },
          {
            "name": "Headcount_",
            "expression": [
              "",
              "VAR EndDate = MAX('Date'[Date])",
              "RETURN",
              "CALCULATE(",
              "    [All Employees],",
              "    people_fact[hire_date] <= EndDate && ",
              "    (people_fact[term_date] > EndDate || ISBLANK(people_fact[term_date]))",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "d0935424-bd75-4d1b-8538-a8b343b6bc11"
          },
          {
            "name": "New Hires",
            "expression": [
              "",
              "CALCULATE(",
              "    [All Employees], ",
              "    'people_fact'[hire_date] >= MIN('Date'[Date]),",
              "    'people_fact'[hire_date] <= MAX('Date'[Date])",
              ") + 0"
            ],
            "formatString": "0",
            "lineageTag": "8fff6117-d3e9-47c0-93ea-affb51bd2277"
          },
          {
            "name": "New Hires YoY %",
            "expression": [
              "",
              "VAR CurrentHires = [New Hires]",
              "VAR PreviousHires = CALCULATE([New Hires], SAMEPERIODLASTYEAR('Date'[Date]))",
              "",
              "RETURN",
              "    IF(",
              "        PreviousHires = 0 && CurrentHires > 0, ",
              "        1,  -- If last year was 0 and now we have hires, show 100% growth",
              "        DIVIDE(CurrentHires - PreviousHires, PreviousHires, 0)",
              "    )"
            ],
            "formatStringDefinition": {
              "expression": "\"+0.0%;-0.0%;0%\""
            },
            "lineageTag": "2517a14b-4ae3-4d96-aec1-74ce21a8e270"
          },
          {
            "name": "Terminations",
            "expression": [
              "",
              "CALCULATE(",
              "    [All Employees], ",
              "    'people_fact'[term_date] >= MIN('Date'[Date]),",
              "    'people_fact'[term_date] <= MAX('Date'[Date])",
              ") + 0"
            ],
            "formatString": "0",
            "lineageTag": "45e3ed41-b74c-459d-b0bc-6adb5704c5ab"
          },
          {
            "name": "New Hire Text",
            "expression": "\"New Hires: \" & format([New Hires],\"###,##0\")",
            "lineageTag": "b1c5aceb-d4a5-4479-afe2-241f6a75adb7"
          },
          {
            "name": "Termination Text",
            "expression": "\"Termination: \" & format([Terminations],\"###,##0\")",
            "lineageTag": "108df94c-ca22-48b6-ae2b-ef3d9519607f"
          },
          {
            "name": "Continuous Retention",
            "expression": [
              "",
              "IF(",
              "    [All Employees] > 0, ",
              "    [Retention], ",
              "    BLANK()",
              ")"
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "a18ea1fc-c32a-431e-bbbb-289cb6caaa02"
          },
          {
            "name": "Tenure at Exit",
            "expression": [
              "",
              "IF(",
              "    NOT(ISBLANK('people_fact'[term_date])),",
              "    DATEDIFF('people_fact'[hire_date], 'people_fact'[term_date], YEAR),",
              "    BLANK()",
              ")"
            ],
            "lineageTag": "916bca1d-c2dd-4db3-b648-f7c025002fe5"
          },
          {
            "name": "Avg Tenure of Leavers",
            "expression": "AVERAGE('people_fact'[Tenure at Exit])",
            "formatStringDefinition": {
              "expression": "\"0.0 Yrs\""
            },
            "lineageTag": "7a038284-b697-4591-942e-696d034fa764"
          },
          {
            "name": "New Hire Retention %",
            "expression": [
              "",
              "VAR TotalNewHires = CALCULATE(COUNTROWS('people_fact'), 'people_fact'[Tenure at Exit] < 1)",
              "RETURN",
              "DIVIDE(TotalNewHires, [All Employees])"
            ],
            "formatString": "0%;-0%;0%",
            "lineageTag": "83d008c9-4cf2-4e25-b15c-ac43f3454391"
          }
        ],
        "partitions": [
          {
            "name": "_Measures-f626f8f8-84c7-4a28-846e-06403afa2cec",
            "mode": "import",
            "queryGroup": "Production Tables",
            "source": {
              "expression": [
                "let",
                "    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText(\"i44FAA==\", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Column1 = _t]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(Source,{{\"Column1\", type text}})",
                "in",
                "    #\"Changed Type\""
              ],
              "type": "m"
            }
          }
        ]
