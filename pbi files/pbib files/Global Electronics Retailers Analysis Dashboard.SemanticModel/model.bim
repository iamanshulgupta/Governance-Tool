          {
            "name": "Online / Physical",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": "IF(dim_stores[StoreKey] = 0, \"Online\", \"Physical\")",
            "isDataTypeInferred": true,
            "lineageTag": "7ff14d48-a84c-4177-a2ed-c70b2a225456",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Store Age",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": "DATEDIFF(dim_stores[Open Date], DATE(2024, 01, 01), YEAR)",
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "8ac14319-3f53-4329-8970-d51dc9885f4a",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "Store Age (Lower Bound)",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "SortByColumn"
              }
            ],
            "dataType": "int64",
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    dim_stores[Store Age] <= 8, 5,",
              "    dim_stores[Store Age] <= 12, 9,",
              "    dim_stores[Store Age] <= 16, 13,",
              "    dim_stores[Store Age] <= 20, 17",
              ")",
              ""
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "731f2778-0943-4c9c-b8bf-291ad27354f8",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "Store Age (Group)",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "changedProperties": [
              {
                "property": "SortByColumn"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    dim_stores[Store Age] >= 5  && dim_stores[Store Age] <= 8,  \"5-8\",",
              "    dim_stores[Store Age] >= 9  && dim_stores[Store Age] <= 12, \"9-12\",",
              "    dim_stores[Store Age] >= 13 && dim_stores[Store Age] <= 16, \"13-16\",",
              "    dim_stores[Store Age] >= 17 && dim_stores[Store Age] <= 20, \"17-20\",",
              "    \"Other\"",
              ")",
              ""
            ],
            "isDataTypeInferred": true,
            "lineageTag": "aeca12a7-4f58-47c6-90c1-fb763916706c",
            "sortByColumn": "Store Age (Lower Bound)",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Store Size (calc)",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": "IF(dim_stores[StoreKey] = 0, 0, dim_stores[Square Meters])",
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "41f9e221-97ac-430b-981a-0d04ad3756ff",
            "summarizeBy": "sum",
            "type": "calculated"
          }
        ],
