          }
        ],
        "lineageTag": "7a7f8744-1225-495f-8f03-ede01b51a7a0",
        "measures": [
          {
            "name": "Total Customers",
            "displayFolder": "Totals",
            "expression": [
              "CALCULATE(",
              "    DISTINCTCOUNT(dim_customers[CustomerKey]),",
              "--    CROSSFILTER('Calendar'[Date], fact_sales[Delivery Date], Both),",
              "    CROSSFILTER(dim_customers[CustomerKey], fact_sales[CustomerKey], Both)",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "27286345-3d82-41e7-990c-20d7aad46dc4"
          },
          {
            "name": "perc_active_customers",
            "displayFolder": "Percentages",
            "expression": [
              "",
              "",
              "VAR selected_category = SELECTEDVALUE(dim_customers[Active/inactive])",
              "",
              "VAR total_customers_for_selected_category = CALCULATE([Total Customers], dim_customers[Active/inactive] = selected_category)",
              "VAR total_active_customers = CALCULATE([Total Customers], dim_customers[Active/inactive] = \"Active\")",
              "",
              "VAR total_customers = CALCULATE([Total Customers], ALL(dim_customers[Active/inactive]))",
              "",
              "RETURN",
              "",
              "IF(",
              "    ISBLANK(selected_category), DIVIDE(total_active_customers, total_customers, 0), ",
              "    DIVIDE(total_customers_for_selected_category, total_customers, 0))"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "6d02267b-96da-4919-94e7-356e896c9134"
          },
          {
            "name": "Total Orders",
            "displayFolder": "Totals",
            "expression": "CALCULATE(DISTINCTCOUNT(fact_sales[Order Number]))",
            "formatString": "#,0",
            "lineageTag": "59ea9095-55a4-437b-b459-8d58cd3ebe12"
          },
          {
            "name": "Total Revenue",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ],
            "displayFolder": "Totals",
            "expression": [
              "CALCULATE(",
              "    SUMX(fact_sales, ",
              "    fact_sales[Quantity] * RELATED(dim_products[Unit Price USD])",
              "    )",
              ")"
            ],
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "84c9d3e1-f49d-4e5d-ad90-c8f3ebe30da0"
          },
          {
            "name": "Total profit",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ],
            "displayFolder": "Totals",
            "expression": [
              "CALCULATE(",
              "    SUMX(fact_sales, ",
              "    fact_sales[Quantity] * RELATED(dim_products[Gross - Profit per product])",
              "    )",
              ")"
            ],
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "4fec7aff-d34c-4e60-acb1-a7babf00ebdb"
          },
          {
            "name": "perc_profit",
            "displayFolder": "Percentages",
            "expression": [
              "",
              "",
              "VAR total_profit = ",
              "CALCULATE(",
              "    SUMX(fact_sales, ",
              "    fact_sales[Quantity] * RELATED(dim_products[Gross - Profit per product])",
              "    )",
              ")",
              "",
              "VAR total_sales = ",
              "CALCULATE(",
              "    SUMX(fact_sales, ",
              "    fact_sales[Quantity] * RELATED(dim_products[Unit Price USD])",
              "    )",
              ")",
              "",
              "RETURN DIVIDE(total_profit, total_sales, 0)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "75649f5d-adeb-4497-92c4-b0df003c51c7"
          },
          {
            "name": "Customers Buying Outside Country",
            "displayFolder": "Totals",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT( fact_sales[CustomerKey] ),",
              "    dim_customers[Traveler Type]  = \"International-Traveler\"",
              "    )",
              ""
            ],
            "formatString": "#,0",
            "lineageTag": "c48eae68-b2cb-4a58-abe0-2c5fd3a64bd7"
          },
          {
            "name": "Cross-Country Transactions",
            "displayFolder": "Totals",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT(fact_sales[Order Number]),",
              "    FILTER(",
              "        fact_sales,",
              "        RELATED(dim_customers[Country]) <> RELATED(dim_stores[Country])",
              "    )",
              ")",
              ""
            ],
            "formatString": "#,0",
            "lineageTag": "b884c65a-b4d9-48f8-b81a-ee05dc33fdc8"
          },
          {
            "name": "Cross-state Transactions",
            "displayFolder": "Totals",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT(fact_sales[Order Number]),",
              "    FILTER(",
              "        fact_sales,",
              "        RELATED(dim_customers[State]) <> RELATED(dim_stores[State])",
              "    )",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "8ef8a0a5-8f32-4199-b5a3-0bf704cd7767"
          },
          {
            "name": "Customers Buying Outside state",
            "displayFolder": "Totals",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT( fact_sales[CustomerKey] ),",
              "    dim_customers[Traveler Type]  = \"Domestic-Traveler\"",
              "    )",
              ""
            ],
            "formatString": "#,0",
            "lineageTag": "483793e6-cb12-40c6-8217-111730c00d75"
          },
          {
            "name": "Customers Buying Local",
            "displayFolder": "Totals",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT( fact_sales[CustomerKey] ),",
              "    dim_customers[Traveler Type]  = \"Local\"",
              "    )"
            ],
            "formatString": "0",
            "lineageTag": "9ac73a4b-f25d-4ed8-b335-d747ecd26c29"
          },
          {
            "name": "perc customers outside state",
            "displayFolder": "Percentages",
            "expression": "DIVIDE([Customers Buying Outside state], [Total Customers], 0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "575bb752-6f99-478a-8078-3e22a0f6a332"
          },
          {
            "name": "perc customers outside country",
            "displayFolder": "Percentages",
            "expression": "DIVIDE([Customers Buying Outside Country], [Total Customers], 0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "7e6ed620-e4dd-4176-a7a3-1f53321e8d6a"
          },
          {
            "name": "perc customers local",
            "displayFolder": "Percentages",
            "expression": "DIVIDE([Customers Buying Local], [Total Customers], 0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "f8a6c0e6-57f2-41ec-93df-98be3d043c82"
          },
          {
            "name": "avg_delivery_days",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Averages",
            "expression": [
              "",
              "",
              "AVERAGE(fact_sales[delivery time (days)])"
            ],
            "lineageTag": "96a3cf12-d404-418f-923b-6ca3cabc7f3d"
          },
          {
            "name": "perc cross-country transactions",
            "displayFolder": "Percentages",
            "expression": [
              "",
              "VAR cross_country_transactions = CALCULATE(",
              "    DISTINCTCOUNT(fact_sales[Order Number]), fact_sales[CrossCountryTransaction] = \"Yes\"",
              ")",
              "",
              "VAR total_transactions = CALCULATE(",
              "    DISTINCTCOUNT(fact_sales[Order Number]), ALL(fact_sales[CrossCountryTransaction])",
              ")",
              "",
              "RETURN DIVIDE(cross_country_transactions, total_transactions, 0)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "aaf4e14f-f319-41a0-b092-962949596837"
          },
          {
            "name": "perc cross-state transactions",
            "displayFolder": "Percentages",
            "expression": [
              "",
              "VAR cross_country_transactions = CALCULATE(",
              "    DISTINCTCOUNT(fact_sales[Order Number]), fact_sales[Cross-State] = \"Yes\"",
              ")",
              "",
              "VAR total_transactions = CALCULATE(",
              "    DISTINCTCOUNT(fact_sales[Order Number]), ALL(fact_sales[Cross-State])",
              ")",
              "",
              "RETURN DIVIDE(cross_country_transactions, total_transactions, 0)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "551ef9cf-fc43-4498-93ac-efb73370f7cf"
          },
          {
            "name": "Avg order per customer",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "displayFolder": "Averages",
            "expression": "ROUND([Total Orders] / [Total Customers], 0)",
            "lineageTag": "4c0241d3-6d70-47a2-8a31-1561958033b5"
          },
          {
            "name": "Customers With More Than Avg Order",
            "displayFolder": "Totals",
            "expression": [
              "CALCULATE(",
              "    DISTINCTCOUNT(fact_sales[CustomerKey]), ",
              "    fact_sales[Orders Per Customer] = 2 || fact_sales[Orders Per Customer] > 2",
              ")",
              ""
            ],
            "formatString": "#,0",
            "lineageTag": "0bb9a7ad-a249-4786-a6bd-63261b1dfdad"
          },
          {
            "name": "perc cust with > avg orders",
            "displayFolder": "Percentages",
            "expression": "DIVIDE([Customers With More Than Avg Order], [Total Customers], 0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "db08ecf3-4bff-4960-9be8-fa3b730c1d61"
          },
          {
            "name": "Total Online customers",
            "displayFolder": "Totals",
            "expression": "CALCULATE(DISTINCTCOUNT(fact_sales[CustomerKey]), fact_sales[Online / In-person] = \"Online\")",
            "formatString": "#,0",
            "lineageTag": "b5c59f99-8f01-4f6f-a7b8-acad68c77a7d"
          },
          {
            "name": "Total Stores",
            "displayFolder": "Totals",
            "expression": "CALCULATE(DISTINCTCOUNT(dim_stores[StoreKey]))",
            "formatString": "0",
            "lineageTag": "a5a09fcd-52e4-4b2d-a049-d0d0e482ee27"
          },
          {
            "name": "Average Store Size",
            "displayFolder": "Averages",
            "expression": "ROUND(CALCULATE(AVERAGE(dim_stores[Square Meters])), 2) &\" m2\"",
            "lineageTag": "d6f59336-60c7-44bb-bc50-772250033015"
          },
          {
            "name": "Total Units Sold",
            "displayFolder": "Totals",
            "expression": "CALCULATE(SUM(fact_sales[Quantity]))",
            "formatString": "#,0",
            "lineageTag": "24f9fec6-c5b4-452a-912f-e8184a37f218"
          },
          {
            "name": "Average Order Value",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ],
            "displayFolder": "Averages",
            "expression": "[Total Revenue] / [Total Orders]",
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "26131b7e-9751-4f71-a733-a1c0c194b66e"
          },
          {
            "name": "Total Products",
            "displayFolder": "Totals",
            "expression": "CALCULATE(DISTINCTCOUNT(dim_products[ProductKey]))",
            "formatString": "#,0",
            "lineageTag": "f005baa7-253c-48b9-9604-1a7e8339116a"
          },
          {
            "name": "Average Product Price",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"currencyCulture\":\"en-US\"}"
              }
            ],
            "displayFolder": "Averages",
            "expression": "ROUND(CALCULATE(SUM(dim_products[Unit Price USD])) / CALCULATE(DISTINCTCOUNT(dim_products[ProductKey])), 0)",
            "formatString": "\\$#,0.###############;(\\$#,0.###############);\\$#,0.###############",
            "lineageTag": "4f371f6e-f784-4098-86c3-3a695773f381"
          },
          {
            "name": "Avg Margin (%)",
            "displayFolder": "Averages",
            "expression": [
              "",
              "DIVIDE(",
              "    SUMX(",
              "        fact_sales,",
              "        (RELATED(dim_products[Unit Price USD]) - RELATED(dim_products[Unit Cost USD])) ",
              "        * fact_sales[Quantity]",
              "    ),",
              "    SUMX(",
              "        fact_sales,",
              "        RELATED(dim_products[Unit Price USD]) * fact_sales[Quantity]",
              "    )",
              ")",
              ""
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "5e2a5ce1-365b-4f7d-bd41-e3d69acd7d32"
          },
          {
            "name": "perc_online_customers",
            "displayFolder": "Percentages",
            "expression": "DIVIDE([Total Online customers], [Total Customers], 0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "4aaaf8f0-7b3f-436f-a461-e92380362ee8"
          }
        ],
        "partitions": [
