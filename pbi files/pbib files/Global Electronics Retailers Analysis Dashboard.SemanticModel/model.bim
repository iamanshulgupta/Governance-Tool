          },
          {
            "name": "Products / Customer",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": [
              "",
              "",
              "VAR current_customer = fact_sales[CustomerKey]",
              "",
              "RETURN ",
              "",
              "CALCULATE(DISTINCTCOUNT(fact_sales[ProductKey]), ",
              "FILTER(fact_sales, ",
              "fact_sales[CustomerKey] = current_customer))",
              ""
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "b914e742-5b85-4578-87c4-1d4c41154c35",
            "summarizeBy": "sum",
