          {
            "name": "Customer Category",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "VAR PurchaseCount =",
              "    CALCULATE(",
              "        DISTINCTCOUNT( fact_sales[Order Number] )",
              "    )",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    PurchaseCount = 0, \"No Purchases\",",
              "    PurchaseCount = 1, \"New Customer\",",
              "    PurchaseCount <= 5 && PurchaseCount > 1, \"Occasional Customer\",",
              "    PurchaseCount <= 10 && PurchaseCount > 5, \"Regular Customer\",",
              "    PurchaseCount > 10, \"Frequent Customer\",",
              "    \"Unknown\"",
              ")",
              ""
            ],
            "isDataTypeInferred": true,
            "lineageTag": "32ef93df-6fc9-4489-8d43-9d86fd2030da",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Traveler Type",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "",
              "",
              "",
              "VAR CrossCountryCount =",
              "    COUNTROWS(",
              "        FILTER(",
              "            fact_sales,",
              "            fact_sales[CustomerKey] = dim_customers[CustomerKey] &&",
              "            LOOKUPVALUE(dim_stores[Country], dim_stores[StoreKey], fact_sales[StoreKey]) ",
              "                <> dim_customers[Country]",
              "        )",
              "    )",
              "VAR CrossStateCount =",
              "    COUNTROWS(",
              "        FILTER(",
              "            fact_sales,",
              "            fact_sales[CustomerKey] = dim_customers[CustomerKey] &&",
              "            LOOKUPVALUE(dim_stores[State], dim_stores[StoreKey], fact_sales[StoreKey])",
              "                <> dim_customers[State] &&",
              "            LOOKUPVALUE(dim_stores[Country], dim_stores[StoreKey], fact_sales[StoreKey])",
              "                = dim_customers[Country]",
              "        )",
              "    )",
              "RETURN",
              "SWITCH(",
              "    TRUE(),",
              "    CrossCountryCount > 0, \"International-Traveler\",",
              "    CrossStateCount > 0, \"Domestic-Traveler\",",
              "    \"Local\"",
              ")",
              ""
            ],
            "isDataTypeInferred": true,
            "lineageTag": "0bad4a9e-e3c3-4e01-a159-a131bfc35887",
            "summarizeBy": "none",
            "type": "calculated"
          }
        ],
