            "expression": "fact_sales[Quantity] * RELATED(dim_products[Gross - Profit per product])",
            "formatString": "\\$#,0.00;(\\$#,0.00);\\$#,0.00",
            "isDataTypeInferred": true,
            "lineageTag": "6c7fbb2f-5dfc-473b-be46-acb58962a7c0",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "Cross-State",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "IF(",
              "    RELATED(dim_customers[State]) <> RELATED(dim_stores[State]),",
              "    \"Yes\",",
              "    \"No\"",
              ")",
              ""
            ],
            "isDataTypeInferred": true,
            "lineageTag": "3a90bbdd-a7e7-47d3-a050-3707d6439bb9",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "CrossCountryTransaction",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "IF(",
              "    RELATED(dim_customers[Country]) <> RELATED(dim_stores[Country]),",
              "    \"Yes\",",
              "    \"No\"",
              ")",
              ""
            ],
            "isDataTypeInferred": true,
            "lineageTag": "fcadac30-8d96-4456-ac42-4989fbd96566",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "delivery time (days)",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": "DATEDIFF(fact_sales[Order Date], fact_sales[Delivery Date], DAY)",
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "2e1056e5-f495-4cc9-9f46-9d704ed9fa4b",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "Orders Per Customer",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": [
              "",
              "",
              "VAR current_customer = fact_sales[CustomerKey]",
              "",
              "RETURN",
              "CALCULATE(",
              "    DISTINCTCOUNT(fact_sales[Order Number]),",
              "    FILTER(",
              "        fact_sales,",
              "        fact_sales[CustomerKey] = current_customer)",
              "    )",
              ""
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
            "lineageTag": "e74feb94-08b1-47ce-8fb0-fe1157c84547",
            "summarizeBy": "sum",
