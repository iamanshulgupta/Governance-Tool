              "expression": [
                "let",
                "    Source = Csv.Document(File.Contents(\"C:\\Users\\moham\\Desktop\\archive\\shopping_behavior_updated (1).csv\"),[Delimiter=\",\", Columns=16, Encoding=1252, QuoteStyle=QuoteStyle.None]),",
