          },
          {
            "name": "Age Group",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "SWITCH(",
              "    TRUE(),",
              "    'Shopping'[Age] >= 18 && 'Shopping'[Age] <= 21, \"18 - 21\",",
              "    'Shopping'[Age] >= 22 && 'Shopping'[Age] <= 25, \"22 - 25\",",
              "    'Shopping'[Age] >= 26 && 'Shopping'[Age] <= 30, \"26 - 30\",",
              "    'Shopping'[Age] >= 31 && 'Shopping'[Age] <= 35, \"31 - 35\",",
              "    'Shopping'[Age] >= 36 && 'Shopping'[Age] <= 40, \"36 - 40\",",
              "    'Shopping'[Age] >= 41 && 'Shopping'[Age] <= 45, \"41 - 45\",",
              "    'Shopping'[Age] >= 46 && 'Shopping'[Age] <= 50, \"46 - 50\",",
              "    'Shopping'[Age] >= 51 && 'Shopping'[Age] <= 55, \"51 - 55\",",
              "    'Shopping'[Age] >= 56, \"56+\",",
              "    \"Unknown\"",
              ")",
              ""
            ],
            "isDataTypeInferred": true,
            "lineageTag": "83c559de-bb4c-4bc9-9d72-52573eb79ec0",
            "summarizeBy": "none",
            "type": "calculated"
          }
        ],
        "lineageTag": "2eb2f850-436a-4fcc-a8a9-7b249f91e374",
        "measures": [
          {
            "name": "Total Customers",
            "expression": "DISTINCTCOUNT('shopping'[Customer ID])",
            "formatString": "0",
            "lineageTag": "af479734-9ed8-4f61-8fd5-e6d998a5750b"
          },
          {
            "name": "Total Revenue",
            "expression": "CALCULATE(SUM('shopping'[Purchase Amount]))",
            "formatString": "0",
            "lineageTag": "622876a2-9754-458a-849f-42181fd1b3d1"
          },
          {
            "name": "Average Purchase value",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE('shopping'[Purchase Amount])",
            "lineageTag": "e2c5f48e-fd9f-4546-b4aa-4f8a63f01299"
          },
          {
            "name": "Subscibers",
            "expression": "CALCULATE(COUNTROWS(shopping), shopping[Subscription Status] = \"Yes\")",
            "formatString": "0",
            "lineageTag": "36b94e3e-7669-4004-bbbd-0f29bd8d9896"
          },
          {
            "name": "Repeating Customers",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNTROWS(VALUES('shopping'[Customer ID])),",
              "    FILTER(",
              "        VALUES('shopping'[Customer ID]),",
              "        COUNTROWS(FILTER('shopping', 'shopping'[Customer ID] = EARLIER('shopping'[Customer ID]))) > 1",
              "    )",
              ")",
              ""
            ],
            "formatString": "0",
            "lineageTag": "b9d2ba0f-8313-4790-8c0c-e0ba655f3a88"
          }
        ],
        "partitions": [
