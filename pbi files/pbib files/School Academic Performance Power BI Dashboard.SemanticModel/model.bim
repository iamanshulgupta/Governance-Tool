        "partitions": [
          {
            "name": "Academic Performance",
            "mode": "import",
            "source": {
              "expression": [
                "let",
                "    Source = Excel.Workbook(File.Contents(\"C:\\Users\\Chandra\\Downloads\\files (1)\\DS04_School_Academic_Performance.xlsx\"), null, true),",
                "    #\"Academic Performance_Sheet\" = Source{[Item=\"Academic Performance\",Kind=\"Sheet\"]}[Data],",
                "    #\"Promoted Headers\" = Table.PromoteHeaders(#\"Academic Performance_Sheet\", [PromoteAllScalars=true]),",
                "    #\"Changed Type\" = Table.TransformColumnTypes(#\"Promoted Headers\",{{\"Student_ID\", type text}, {\"Name\", type text}, {\"Class\", type text}, {\"Section\", type text}, {\"Gender\", type text}, {\"English\", Int64.Type}, {\"Math\", Int64.Type}, {\"Science\", Int64.Type}, {\"Social_Studies\", Int64.Type}, {\"Computer\", Int64.Type}, {\"Total\", Int64.Type}, {\"Percentage\", type number}, {\"Grade\", type text}, {\"Attendance_Pct\", type number}, {\"Extracurricular\", type text}})",
                "in",
                "    #\"Changed Type\""
              ],
              "type": "m"
            }
          }
        ]
      },
      {
        "name": "_Measure",
        "annotations": [
          {
            "name": "PBI_Id",
            "value": "51a92e9d8719491685fcb86e68b90c92"
          }
        ],
        "columns": [
          {
            "name": "Value",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "isDataTypeInferred": true,
            "isNameInferred": true,
            "lineageTag": "78f4969f-dae5-4703-ad5e-2afcb3e41a99",
            "sourceColumn": "[Value]",
            "summarizeBy": "none",
            "type": "calculatedTableColumn"
          }
        ],
        "lineageTag": "67f00ad3-fe42-4bc4-b53c-b4a7df04981e",
        "measures": [
          {
            "name": "Total Students",
            "expression": [
              "",
              "DISTINCTCOUNT('Academic Performance'[Student_ID])"
            ],
            "formatString": "0",
            "lineageTag": "10ceaa00-d57a-431c-b55e-c70a78c092d9"
          },
          {
            "name": "Avg Percentage",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "AVERAGE('Academic Performance'[Percentage])"
            ],
            "lineageTag": "bbd20c96-2b44-488e-9c6f-80a3aa9f3530"
          },
          {
            "name": "Avg Attendance",
            "expression": [
              "DIVIDE(",
              "AVERAGE('Academic Performance'[Attendance_Pct]),100)"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "e69471ad-23e8-43a7-adff-37fac1a364a2"
          },
          {
            "name": "Avg Total Marks",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "AVERAGE('Academic Performance'[Total])"
            ],
            "lineageTag": "7a628fec-c9fb-4e82-be30-a87dafb0ee83"
          },
          {
            "name": "Top Students",
            "expression": [
              "",
              "CALCULATE(",
              "COUNTROWS('Academic Performance'),",
              "'Academic Performance'[Percentage] >= 75",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "5be2a772-9be7-41ab-a657-f2f9787d05a6"
          },
          {
            "name": "Top Student Rate",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "DIVIDE([Top Students],[Total Students])"
            ],
            "lineageTag": "cce66e9b-8d31-4e39-bef9-db72a3f266b1"
          },
          {
            "name": "Student KPI Details",
            "expression": [
              "",
              "\"Top Performers: \" &",
              "FORMAT([Top Students],\"#,##0\")",
              "& \" | Avg %: \" &",
              "FORMAT([Avg Percentage],\"0.0\")"
            ],
            "lineageTag": "1ac67368-9d08-4070-a736-d98c44fad03c"
          },
          {
            "name": "Grade A Students",
            "expression": [
              "",
              "CALCULATE(",
              "COUNTROWS('Academic Performance'),",
              "'Academic Performance'[Grade] = \"A\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "6998857c-0052-41db-8d51-ba243449b0b5"
          },
          {
            "name": "Grade A Rate",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "DIVIDE([Grade A Students],[Total Students])"
            ],
            "lineageTag": "1b7a5e1d-131a-4b7d-a928-39edd1fa579c"
          },
          {
            "name": "Score KPI Details",
            "expression": [
              "",
              "\"Avg Marks: \" &",
              "FORMAT([Avg Total Marks],\"0\")",
              "& \" | Grade A: \" &",
              "FORMAT([Grade A Rate],\"0%\")"
            ],
            "lineageTag": "c9be9275-06ea-47ee-836d-7b3c81d88547"
          },
          {
            "name": "Low Attendance Students",
            "expression": [
              "",
              "CALCULATE(",
              "COUNTROWS('Academic Performance'),",
              "'Academic Performance'[Attendance_Pct] < 75",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "0dd60d15-0918-43d3-99f1-af97b24b67e9"
          },
          {
            "name": "Low Attendance Rate",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "DIVIDE([Low Attendance Students],[Total Students])"
            ],
            "lineageTag": "bf47ef88-4c38-4b21-ab14-5e0bc781d96e"
          },
          {
            "name": "Attendance KPI Details",
            "expression": [
              "",
              "\"Low Attendance: \" &",
              "FORMAT([Low Attendance Rate],\"0%\")",
              "& \" | Avg Attendance: \" &",
              "FORMAT([Avg Attendance],\"0%\")"
            ],
            "lineageTag": "86fac14a-7b4c-4335-bfd5-e9c25df5767e"
          },
          {
            "name": "Active Students",
            "expression": [
              "",
              "CALCULATE(",
              "COUNTROWS('Academic Performance'),",
              "'Academic Performance'[Extracurricular] <> \"None\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "4d6352e2-b359-423c-b545-672558fd6bc8"
          },
          {
            "name": "Activity Rate",
            "expression": [
              "",
              "DIVIDE([Active Students],[Total Students])"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "50809820-969c-4556-97b1-1198f35a9e41"
          },
          {
            "name": "Engagement KPI Details",
            "expression": [
              "",
              "\"Extracurricular: \" &",
              "FORMAT([Activity Rate],\"0%\")",
              "& \" | Active Students: \" &",
              "FORMAT([Active Students],\"#,##0\")"
            ],
            "lineageTag": "3b10abf8-8b19-4761-8519-b1d30cc3e671"
          },
          {
            "name": "Avg English",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE('Academic Performance'[English])",
            "lineageTag": "e376756e-02dc-46fe-962b-c59e14a36be0"
          },
          {
            "name": "Avg Math",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE('Academic Performance'[Math])",
            "lineageTag": "ed23df97-b8d5-4aeb-a9e0-08be14bc6e22"
          },
          {
            "name": "Avg Science",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE('Academic Performance'[Science])",
            "lineageTag": "c0414658-0358-4288-9b3e-86d5c37cf980"
          },
          {
            "name": "Avg Social Studies",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE('Academic Performance'[Social_Studies])",
            "lineageTag": "7384e81b-8993-470d-8496-ca013972d4b2"
          },
          {
            "name": "Avg Computer",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "AVERAGE('Academic Performance'[Computer])",
            "lineageTag": "e8624043-831e-49b9-9e28-13909671ba4f"
          }
        ],
        "partitions": [
          {
            "name": "_Measure",
            "mode": "import",
